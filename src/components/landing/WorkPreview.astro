---
/* src/components/landing/WorkPreview.astro */
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const { class: className } = Astro.props;

// Cargamos los 8 proyectos solicitados
const allProjects = (await getCollection("projects"))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 8); 
---

<section id="work-preview-section" class:list={["w-full bg-[#050505] pt-40 pb-20", className]}>
    <div class="max-w-[1440px] mx-auto px-6 md:px-12 mb-20">
        <div class="flex flex-col gap-6 border-l border-white pl-10">
            <span class="font-mono text-zinc-600 text-[10px] tracking-[0.5em] uppercase font-bold">
                Portfolio // 2026
            </span>
            <h2 class="text-6xl md:text-8xl lg:text-9xl font-black uppercase italic tracking-tighter leading-[0.8] text-white">
                PROYECTOS <br/>
                <span class="text-zinc-800 hover:text-white transition-colors duration-700">DESTACADOS.</span>
            </h2>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 w-full border-t border-zinc-900">
        {
            allProjects.map((project, index) => {
                const imgSource = project.data.image?.source;
                const imgAlt = project.data.image?.alt || project.data.title;
                const projectId = `_0${index + 1}`;
                
                return (
                    <a href={`/work/${project.slug}`} class="group relative aspect-[3/4] overflow-hidden border-r border-b border-zinc-900 bg-zinc-950 block">
                        <div class="absolute top-6 left-6 z-30 font-mono text-[10px] text-zinc-700 group-hover:text-white transition-colors">
                            {projectId}
                        </div>

                        <div class="absolute inset-0 z-10 overflow-hidden">
                            {imgSource ? (
                                <Image 
                                    src={imgSource} 
                                    alt={imgAlt}
                                    width={600}
                                    height={800}
                                    class="w-full h-full object-cover grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-1000 ease-in-out"
                                />
                            ) : (
                                <div class="w-full h-full bg-zinc-900 flex items-center justify-center font-mono text-[10px] text-zinc-800">DATA_EMPTY</div>
                            )}
                            <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-transparent to-transparent opacity-80 group-hover:opacity-30 transition-opacity" />
                        </div>

                        <div class="relative z-20 h-full p-8 md:p-10 flex flex-col justify-end items-start translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
                            <p class="font-mono text-[9px] text-zinc-500 uppercase tracking-widest mb-3 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                                {project.data.category || "Development"}
                            </p>
                            <h3 class="text-3xl font-black uppercase italic tracking-tighter text-white leading-none">
                                {project.data.title}
                            </h3>
                            <div class="mt-4 h-px w-0 bg-white group-hover:w-full transition-all duration-700 ease-out shadow-[0_0_10px_rgba(255,255,255,0.5)]" />
                        </div>
                    </a>
                )
            })
        }
    </div>
</section>