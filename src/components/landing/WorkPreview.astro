---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const { class: className } = Astro.props;

const allProjects = (await getCollection("projects"))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 8); 
---

<section id="work-preview-section" class:list={["w-full bg-zinc-950 pt-20", className]}>
    <div class="max-w-7xl mx-auto px-8 pb-12 md:px-12 w-full text-white">
        <div class="flex flex-col gap-2 border-l border-lime-400/30 pl-6">
            <span class="font-mono text-lime-400 text-xs tracking-[0.3em] uppercase">Portafolio Seleccionado</span>
            <h2 class="text-4xl md:text-6xl font-black uppercase tracking-tighter leading-none">
                Proyectos<span class="text-lime-400">_</span>
            </h2>
        </div>
    </div>

    <div class="inspiro-grid border-y border-zinc-900">
        {
            allProjects.map((project) => {
                const imgSource = project.data.image?.source;
                const imgAlt = project.data.image?.alt || project.data.title;
                
                return (
                    <a href={`/work/${project.slug}`} class="work-item group border-zinc-900 border-r border-b">
                        <div class="image-container bg-zinc-950">
                            {imgSource ? (
                                <Image 
                                    src={imgSource} 
                                    alt={imgAlt}
                                    width={800}
                                    height={800}
                                    class="project-img grayscale hover:grayscale-0"
                                />
                            ) : (
                                <div class="flex h-full w-full items-center justify-center text-zinc-800 font-mono text-[10px]">
                                    NO_IMAGE_DATA
                                </div>
                            )}
                            <div class="overlay"></div>
                        </div>

                        <div class="content">
                            <span class="tag">{project.data.tags?.[0] || "Software"}</span>
                            <h3 class="title">{project.data.title}</h3>
                            <div class="line"></div>
                        </div>
                    </a>
                )
            })
        }
    </div>
</section>

<style>
    .inspiro-grid {
        display: grid;
        grid-template-columns: repeat(1, 1fr);
        width: 100%;
        background-color: #09090b;
    }

    @media (min-width: 640px) { .inspiro-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1024px) { .inspiro-grid { grid-template-columns: repeat(4, 1fr); } }

    .work-item {
        position: relative;
        aspect-ratio: 1 / 1.1; /* Un poco más vertical para elegancia */
        overflow: hidden;
        display: block;
    }

    .image-container {
        position: absolute;
        inset: 0;
    }

    .project-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        opacity: 0.6;
    }

    .work-item:hover .project-img {
        transform: scale(1.08);
        opacity: 1;
        filter: grayscale(0);
    }

    .overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(9, 9, 11, 0.9) 0%, transparent 60%);
        transition: opacity 0.5s ease;
    }

    .work-item:hover .overlay { opacity: 0.2; }

    .content {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-end; /* Contenido abajo para no tapar toda la imagen */
        z-index: 20;
        padding-bottom: 3rem;
        text-align: center;
    }

    .tag {
        font-family: monospace;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        color: #a3e635;
        margin-bottom: 8px;
        transform: translateY(10px);
        opacity: 0;
        transition: all 0.4s ease;
    }

    .title {
        font-weight: 700;
        text-transform: uppercase;
        color: white;
        font-size: 1.1rem;
        letter-spacing: 0.05em;
        transform: translateY(10px);
        opacity: 0;
        transition: all 0.4s ease 0.1s;
    }

    .line {
        height: 1px;
        width: 0;
        background-color: #a3e635;
        margin-top: 1rem;
        transition: width 0.5s ease 0.2s;
    }

    .work-item:hover .tag, .work-item:hover .title {
        transform: translateY(0);
        opacity: 1;
    }

    .work-item:hover .line { width: 40px; }
</style>