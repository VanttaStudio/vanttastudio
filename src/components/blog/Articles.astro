---
/* src/components/blog/Articles.astro */
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { getLangFromUrl, useTranslatedPath } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);

/** * OBTENCIÓN DE DATOS CORREGIDA: 
 * Se elimina el filtro de idioma del slug porque los archivos 
 * ahora están directamente en src/content/posts/.
 */
const allPosts = (await getCollection("posts"))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Función para simular peso de archivo técnico basado en el contenido
const getFileSize = (content: string = "") => {
    const size = content ? (content.length / 1024).toFixed(2) : "14.20";
    return `${size} KB`;
};
---

<div class="flex flex-col border-t border-zinc-900 bg-black/20">
    {
        allPosts.map((post, index) => {
            // El slug ahora es el nombre directo del archivo
            const cleanSlug = post.slug; 
            const recordID = (index + 1).toString().padStart(2, '0');
            const hexID = `0x${(index + 2048).toString(16).toUpperCase()}`;
            
            return (
                <a 
                    href={translatePath(`/blog/${cleanSlug}`)} 
                    class="group relative w-full border-b border-zinc-900 py-12 lg:py-20 hover:bg-lime-400/[0.01] transition-all duration-500 overflow-hidden block text-decoration-none"
                >
                    <span class="absolute right-8 top-1/2 -translate-y-1/2 text-[14vw] font-black text-white/[0.01] pointer-events-none group-hover:text-lime-400/[0.02] transition-colors italic select-none">
                        {hexID}
                    </span>

                    <div class="container relative z-10 mx-auto px-0">
                        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start lg:items-center">
                            
                            <div class="lg:col-span-2 hidden lg:flex flex-col gap-8 font-mono text-[9px] text-zinc-600 uppercase tracking-[0.2em]">
                                <div class="space-y-2">
                                    <span class="text-lime-400 block">// OBJECT_ID</span>
                                    <span class="text-zinc-300">VNTT_LOG_{recordID}</span>
                                </div>
                                <div class="space-y-2">
                                    <span class="text-zinc-700 block">DATA_SIZE:</span>
                                    <span class="text-zinc-400">{getFileSize(post.body)}</span>
                                </div>
                                <div class="space-y-2">
                                    <span class="text-zinc-700 block">STATUS:</span>
                                    <span class="flex items-center gap-2">
                                        <span class="h-1 w-1 bg-lime-400 rounded-full animate-pulse"></span> 
                                        STABLE
                                    </span>
                                </div>
                            </div>

                            <div class="lg:col-span-7 flex flex-col gap-8">
                                <div class="flex flex-wrap gap-2">
                                    {post.data.tags?.map((tag: string) => (
                                        <span class="text-[8px] font-mono border border-zinc-800 px-3 py-1 text-zinc-500 uppercase tracking-widest group-hover:border-lime-400/40 group-hover:text-lime-400 transition-colors bg-black">
                                            [{tag}]
                                        </span>
                                    ))}
                                </div>
                                
                                <div class="space-y-6">
                                    <h2 class="text-4xl md:text-6xl lg:text-7xl font-black uppercase italic tracking-[calc(-0.04em)] leading-[0.85] text-zinc-200 group-hover:text-white group-hover:translate-x-4 transition-all duration-700 ease-out">
                                        {post.data.title}
                                    </h2>
                                    <p class="max-w-2xl text-zinc-500 text-lg font-light leading-relaxed opacity-70 group-hover:opacity-100 transition-opacity duration-500">
                                        {post.data.description}
                                    </p>
                                </div>

                                <div class="flex items-center gap-6 mt-4">
                                    <span class="font-mono text-[9px] text-zinc-700 uppercase tracking-widest">
                                        Timestamp: <span class="text-zinc-500">{post.data.pubDate.toLocaleDateString(lang, { day: '2-digit', month: '2-digit', year: 'numeric' }).replace(/\//g, '.')}</span>
                                    </span>
                                    <span class="h-px w-12 bg-zinc-900 group-hover:bg-lime-400/20 transition-colors"></span>
                                    <span class="font-mono text-[9px] text-lime-400/40 uppercase animate-pulse">Ready_to_load_</span>
                                </div>
                            </div>

                            <div class="lg:col-span-3">
                                <div class="relative aspect-[16/10] w-full grayscale group-hover:grayscale-0 transition-all duration-1000 overflow-hidden border border-zinc-900 group-hover:border-lime-400/20 shadow-[0_0_50px_rgba(0,0,0,0.5)]">
                                    <Image 
                                        src={post.data.image.source} 
                                        alt={post.data.image.alt || post.data.title}
                                        width={600}
                                        height={375}
                                        class="object-cover w-full h-full scale-110 group-hover:scale-100 transition-transform duration-1000"
                                    />
                                    
                                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-lime-400/20 to-transparent h-[20%] w-full -translate-y-full group-hover:animate-scan pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                    
                                    <div class="absolute top-0 right-0 h-3 w-3 border-t border-r border-lime-400/50 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                    <div class="absolute bottom-0 left-0 h-3 w-3 border-b border-l border-lime-400/50 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                </div>
                            </div>

                        </div>
                    </div>

                    <div class="absolute left-0 top-0 h-full w-0 group-hover:w-1 bg-lime-400 transition-all duration-500 shadow-[0_0_15px_rgba(163,230,53,0.5)]"></div>
                </a>
            )
        })
    }
</div>

<style>
    /* Laser Scan Animation */
    @keyframes scan {
        0% { transform: translateY(-100%); }
        100% { transform: translateY(500%); }
    }
    .animate-scan {
        animation: scan 2.5s linear infinite;
    }

    /* Optimización de Renderizado */
    h2, p, img, a {
        backface-visibility: hidden;
        -webkit-font-smoothing: antialiased;
    }
</style>