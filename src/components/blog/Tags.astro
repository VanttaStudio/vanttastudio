---
/* src/components/blog/Tags.astro */
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import Title from "@components/global/Title.astro";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// 1. Obtención y filtrado de posts por idioma para extraer tags precisos
const allPosts = (await getCollection("posts"))
    .filter((post) => {
        const [postLang] = post.slug.split("/");
        return postLang === lang;
    });

// 2. Extracción de tags únicos y conteo de densidad de archivos
const tagCounts = allPosts.reduce((acc, post) => {
    post.data.tags.forEach(tag => {
        acc[tag] = (acc[tag] || 0) + 1;
    });
    return acc;
}, {} as Record<string, number>);

const tags = Object.keys(tagCounts).sort();
---

<section class="relative bg-zinc-950 text-white min-h-screen overflow-hidden selection:bg-lime-400 selection:text-black">
    
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" 
         style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 40px 40px;">
    </div>
    <div class="absolute top-0 left-1/3 w-px h-full bg-zinc-900/30 pointer-events-none hidden lg:block"></div>

    <div class="container relative z-10 mx-auto px-6 py-24 md:px-12 lg:pt-32 2xl:max-w-7xl">
        
        <header class="relative mb-20 md:mb-32">
            <div class="absolute -top-6 -left-2 font-mono text-zinc-800 text-[10px] tracking-[0.5em] uppercase">
                [ DATABASE_INDEX // SEGMENT_SORT ]
            </div>
            
            <div class="flex flex-col gap-6">
                <div class="flex items-center gap-4">
                    <span class="h-px w-12 bg-lime-400"></span>
                    <span class="font-mono text-lime-400 text-[10px] uppercase tracking-[0.5em] animate-pulse">
                        Scanning_Available_Sectors
                    </span>
                </div>
                <Title 
                    class="uppercase font-black italic tracking-tighter text-7xl md:text-[9rem] lg:text-[11rem] leading-[0.75] text-white" 
                    title="Segments_" 
                    subtitle={lang === 'es' ? 'Clasificación de datos técnicos' : 'Technical data classification'} 
                />
            </div>
        </header>
        
        <div class="mt-12">
            <ol class="flex flex-col border-t border-zinc-900">
                {
                    tags.map((tag, index) => {
                        const segmentID = `SEG_${(index + 1).toString().padStart(2, '0')}`;
                        const density = tagCounts[tag];
                        
                        return (
                            <li class="group relative border-b border-zinc-900 transition-all duration-700 hover:bg-lime-400/[0.02]">
                                <span class="absolute left-1/3 top-1/2 -translate-y-1/2 font-mono text-[8vw] font-black text-white/[0.01] pointer-events-none group-hover:text-lime-400/[0.03] transition-colors duration-700 italic select-none">
                                    {segmentID}
                                </span>

                                <a 
                                    href={translatePath(`/tags/${tag}`)} 
                                    class="flex w-full items-center justify-between py-12 md:py-16 px-0"
                                    data-cursor-hover
                                >
                                    <div class="flex items-center gap-8 md:gap-16 relative z-10">
                                        <span class="font-mono text-zinc-800 group-hover:text-lime-400 transition-colors text-xs md:text-sm">
                                            {index + 1}.
                                        </span>

                                        <div class="flex flex-col gap-2">
                                            <div class="flex items-center gap-3">
                                                <span class="text-lime-400 font-mono text-[10px] opacity-0 group-hover:opacity-100 transition-opacity">#</span>
                                                <h3 class="text-4xl font-black uppercase italic tracking-tighter md:text-6xl lg:text-7xl text-zinc-300 group-hover:text-white group-hover:translate-x-4 transition-all duration-700 ease-out">
                                                    {tag}
                                                </h3>
                                            </div>
                                            <div class="flex items-center gap-4 ml-0 md:ml-6">
                                                <span class="h-px w-4 bg-zinc-800 group-hover:bg-lime-400 transition-colors"></span>
                                                <span class="font-mono text-[9px] uppercase tracking-widest text-zinc-600">
                                                    Density: {density.toString().padStart(2, '0')} FILES_LOGGED
                                                </span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="flex items-center gap-8 pr-4">
                                        <div class="hidden md:block font-mono text-[9px] text-zinc-800 opacity-0 group-hover:opacity-100 transition-all uppercase tracking-widest translate-x-4 group-hover:translate-x-0">
                                            Access_Sector
                                        </div>
                                        <div class="flex h-12 w-12 items-center justify-center rounded-none border border-zinc-900 text-zinc-800 transition-all duration-500 group-hover:border-lime-400 group-hover:text-lime-400 group-hover:bg-lime-400/5">
                                            <Icon name="ic:baseline-arrow-right-alt" class="w-8 h-8 group-hover:translate-x-1 transition-transform" />
                                        </div>
                                    </div>
                                </a>
                                
                                <div class="absolute bottom-0 left-0 h-[2px] w-0 bg-lime-400 transition-all duration-1000 ease-in-out group-hover:w-full shadow-[0_0_15px_#a3e635]"></div>
                            </li>
                        );
                    })
                }
            </ol>
        </div>

        <div class="mt-24 py-8 border-t border-zinc-900 flex justify-between items-center font-mono text-[9px] text-zinc-700 uppercase tracking-[0.4em]">
            <span>Sector_Analysis_Complete</span>
            <div class="flex gap-8">
                <span>Total_Clusters: {tags.length}</span>
                <span class="text-zinc-800 animate-pulse">Syncing_Segments...</span>
            </div>
        </div>
    </div>
</section>

<style is:global>
    /* Tipografía técnica agresiva */
    h1, h3, .tag-title {
        @apply font-black uppercase italic tracking-tighter;
    }

    /* Industrial Reveal Animation */
    .animate-reveal {
        clip-path: polygon(0 0, 0 0, 0 100%, 0% 100%);
        animation: reveal-industrial 1.4s cubic-bezier(0.19, 1, 0.22, 1) forwards;
    }

    @keyframes reveal-industrial {
        to { clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%); }
    }
</style>