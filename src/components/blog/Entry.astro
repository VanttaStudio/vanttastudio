---
/* src/components/blog/Entry.astro */
import { Image } from "astro:assets";
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const { title, url, author, pubDate, description, image, titleInside = false } = Astro.props;

// Generador de ID técnico aleatorio para la estética del registro
const fileId = `FILE_VNTT_${Math.random().toString(36).substring(2, 6).toUpperCase()}`;
---

<a href={translatePath(url)} title={title} class="group block h-full relative" data-cursor-hover>
    <article class="relative flex h-full flex-col overflow-hidden rounded-none border border-zinc-900 bg-zinc-950 transition-all duration-700 hover:border-lime-400/30">
        
        <div class="absolute top-2 left-2 z-30 font-mono text-[8px] text-zinc-800 group-hover:text-lime-400/50 transition-colors uppercase">
            [ {fileId} ]
        </div>

        <div class:list={[
            "relative block w-full overflow-hidden aspect-[16/10] border-b border-zinc-900 transition-colors duration-700 group-hover:border-lime-400/20",
            titleInside ? "after:absolute after:inset-0 after:bg-gradient-to-t after:from-zinc-950 after:via-zinc-950/40 after:to-transparent after:z-10" : ""
        ]}>
            <Image 
                class="h-full w-full object-cover transition-all duration-1000 ease-out group-hover:scale-105 grayscale brightness-75 group-hover:grayscale-0 group-hover:brightness-100" 
                src={image} 
                alt={title} 
                width={800}
                height={500}
            />
            
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-lime-400/20 to-transparent h-[15%] w-full -translate-y-full group-hover:animate-scan z-20 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity"></div>

            {titleInside && (
                <div class="absolute bottom-0 left-0 z-20 p-6 md:p-8 w-full">
                    <div class="flex items-center gap-2 mb-4">
                        <span class="h-px w-6 bg-lime-400"></span>
                        <span class="font-mono text-[9px] text-lime-400 uppercase tracking-widest">Featured_Entry</span>
                    </div>
                    <h2 class="text-3xl font-black uppercase italic leading-[0.85] tracking-tighter text-white md:text-5xl group-hover:translate-x-2 transition-transform duration-700">
                        {title}
                    </h2>
                </div>
            )}
        </div>

        <div class:list={[
            "flex flex-1 flex-col justify-between p-6 md:p-8 relative",
            titleInside ? "hidden" : "flex"
        ]}>
            <div class="w-full">
                <div class="mb-4 font-mono text-[9px] text-zinc-600 uppercase tracking-widest flex items-center gap-2">
                    <span class="text-lime-400">//</span> 01_CONTENT_STREAM
                </div>
                
                <h3 class="text-2xl font-black uppercase italic tracking-tighter text-zinc-200 transition-colors group-hover:text-white md:text-3xl leading-none">
                    {title}
                </h3>
                
                <p class="mt-4 line-clamp-3 font-light text-sm leading-relaxed text-zinc-500 group-hover:text-zinc-400 transition-colors">
                    {description}
                </p>
            </div>

            <footer class="mt-8 flex items-center justify-between border-t border-zinc-900 pt-6 font-mono text-[9px] uppercase tracking-widest">
                <div class="flex items-center space-x-4">
                    <div class="flex flex-col">
                        <span class="text-zinc-700">Author:</span>
                        <span class="text-zinc-400 group-hover:text-white transition-colors">{author.name}</span>
                    </div>
                </div>
                <div class="flex flex-col text-right">
                    <span class="text-zinc-700">Sync_Date:</span>
                    <time datetime={pubDate} class="text-lime-400/70 group-hover:text-lime-400 transition-colors">
                        {pubDate}
                    </time>
                </div>
            </footer>
        </div>
        
        <div class="absolute bottom-0 left-0 h-[2px] w-0 bg-lime-400 transition-all duration-1000 ease-in-out group-hover:w-full shadow-[0_0_10px_#a3e635]"></div>
    </article>
</a>

<style>
    /* Scanner técnico mejorado */
    @keyframes scan {
        0% { transform: translateY(-100%); }
        100% { transform: translateY(600%); }
    }
    .animate-scan {
        animation: scan 2.5s linear infinite;
    }

    /* Grano de película técnico (Blueprints) */
    article::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        opacity: 0.02;
        pointer-events: none;
        z-index: 40;
    }
</style>