---
/* src/components/blog/Cta.astro */
import Newsletter from "@components/blog/Newsletter.astro";
import { getLangFromUrl, useTranslations } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative overflow-hidden bg-zinc-950 py-32 lg:py-56 border-t border-zinc-900 selection:bg-lime-400 selection:text-black">
    
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" 
         style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 40px 40px;">
    </div>
    
    <div class="absolute left-1/2 top-0 h-full w-px bg-gradient-to-b from-transparent via-zinc-800 to-transparent"></div>

    <div class="mx-auto max-w-7xl px-8 md:px-12 lg:px-32 relative z-10">
        <div class="absolute -top-12 left-8 font-mono text-zinc-800 text-[9px] uppercase tracking-[0.4em]">
            [ SYS_SYNC_INITIALIZED ]
        </div>

        <div class="flex flex-col items-center justify-center gap-16 text-center">
            
            <div class="flex flex-col items-center gap-6">
                <div class="flex items-center gap-3">
                    <span class="h-1 w-1 bg-lime-400 animate-ping"></span>
                    <span class="font-mono text-[10px] uppercase tracking-[0.5em] text-lime-400">
                        {t("newsletter.pretitle") || "JOIN_THE_ARRAY"}
                    </span>
                </div>
                
                <h2 class="max-w-5xl font-black uppercase italic leading-[0.8] tracking-tighter text-white text-6xl md:text-[8rem] lg:text-[11rem]">
                    INICIAR EL <br />
                    <span class="outline-text">PROTOCOLO_</span>
                </h2>
            </div>

            <div class="max-w-2xl w-full flex flex-col gap-10 items-center">
                <p class="max-w-lg font-mono text-[11px] uppercase tracking-widest leading-relaxed text-zinc-500">
                    {t("newsletter.description") || "Sincroniza tu bandeja de entrada con nuestras últimas investigaciones sobre ingeniería, diseño brutalista y rendimiento digital."}
                </p>

                <div class="w-full">
                    <Newsletter class="w-full" />
                </div>
            </div>

            <div class="flex items-center gap-8 font-mono text-[8px] text-zinc-700 uppercase tracking-[0.6em]">
                <span>Secure_Transmission</span>
                <span class="hidden md:block">//</span>
                <span>No_Third_Party_Tracking</span>
            </div>
        </div>
    </div>

    <div class="absolute bottom-10 right-10 font-mono text-zinc-900 text-[10px]">
        {new Date().getFullYear()} // VNTT_R&D
    </div>
</section>

<style is:global>
    /* Estilo de texto "Hollow" Industrial */
    .outline-text {
        color: transparent;
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.1);
        transition: all 0.7s cubic-bezier(0.19, 1, 0.22, 1);
    }

    section:hover .outline-text {
        -webkit-text-stroke: 1px rgba(163, 230, 53, 0.8);
        text-shadow: 0 0 20px rgba(163, 230, 53, 0.2);
    }

    /* Aseguramos que el layout no se rompa */
    h2 {
        text-wrap: balance;
    }
</style>