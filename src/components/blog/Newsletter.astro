---
/* src/components/blog/Newsletter.astro */
const { class: className } = Astro.props;
import { getLangFromUrl, useTranslations } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class:list={["relative max-w-[30rem] lg:max-w-[35rem] group", className]}>
    <div class="flex justify-between items-center mb-2 px-1">
        <span class="font-mono text-[9px] text-zinc-600 uppercase tracking-[0.3em]">
            [ STRE_INPUT_CH-01 ]
        </span>
        <span class="font-mono text-[9px] text-lime-400/50 uppercase tracking-widest opacity-0 group-within:opacity-100 transition-opacity">
            Ready_to_sync_
        </span>
    </div>

    <div class="relative h-16 w-full bg-zinc-950 border border-zinc-900 transition-all duration-500 group-within:border-lime-400/50 group-within:shadow-[0_0_20px_rgba(163,230,53,0.05)]">
        
        <div class="absolute -top-px -left-px h-2 w-2 border-t border-l border-zinc-800 group-within:border-lime-400 transition-colors"></div>
        <div class="absolute -bottom-px -right-px h-2 w-2 border-b border-r border-zinc-800 group-within:border-lime-400 transition-colors"></div>

        <form class="relative h-full flex items-center overflow-hidden">
            <input
                type="email"
                name="EMAIL"
                required
                autocomplete="email"
                placeholder={t("footer.yourmail") || "ENTER_MAIL_ADDRESS_"}
                class="pointer-events-auto h-full w-full bg-transparent px-6 text-sm font-mono uppercase tracking-wider text-white outline-none placeholder:text-zinc-800 focus:ring-0"
            />
            
            <button
                type="submit"
                aria-label="Execute Sync"
                data-cursor-hover
                class="h-full px-8 bg-zinc-900 text-zinc-500 border-l border-zinc-900 transition-all duration-500 hover:bg-lime-400 hover:text-black hover:border-lime-400 group/btn flex items-center gap-3"
            >
                <span class="font-mono text-[10px] font-black uppercase tracking-tighter hidden md:block">
                    Exec_
                </span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="transition-transform duration-500 group-hover/btn:translate-x-1">
                    <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="square"/>
                </svg>
            </button>
        </form>

        <div class="absolute inset-0 bg-lime-400/5 h-full w-full pointer-events-none opacity-0 group-within:opacity-100 group-within:animate-pulse"></div>
    </div>

    <div class="flex justify-between mt-3 px-1 font-mono text-[8px] text-zinc-700 uppercase tracking-[0.2em]">
        <span>Encryption: AES_256</span>
        <div class="flex gap-4">
            <span>Auth_Status: PENDING</span>
            <span class="text-zinc-800">//</span>
            <span>VNTT_SYS_01</span>
        </div>
    </div>
</div>

<style>
    /* Estética de Input Terminal */
    input::placeholder {
        font-size: 10px;
        letter-spacing: 0.2em;
    }

    /* Animación sutil de borde para simular carga de datos */
    @keyframes pulse-border {
        0%, 100% { border-color: rgba(163, 230, 53, 0.2); }
        50% { border-color: rgba(163, 230, 53, 0.5); }
    }

    input:focus ~ .laser-line {
        animation: scan 2s linear infinite;
    }
</style>