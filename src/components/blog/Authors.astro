---
/* src/components/blog/Authors.astro */
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import Title from "@components/global/Title.astro";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const allAuthors = (await getCollection("authors"))
    .filter((author) => {
        const [authorLang] = author.slug.split("/");
        return authorLang === lang;
    })
    .map((author) => {
        const [authorLang, slug] = author.slug.split("/");
        return {
            ...author,
            slug: slug,
        };
    });
---

<section class="relative bg-zinc-950 text-white min-h-screen overflow-hidden selection:bg-lime-400 selection:text-black">
    
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" 
         style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 40px 40px;">
    </div>
    <div class="absolute top-0 left-1/4 w-px h-full bg-zinc-900/30 pointer-events-none hidden lg:block"></div>

    <div class="container relative z-10 mx-auto px-6 py-24 md:px-12 lg:pt-32 2xl:max-w-7xl">
        
        <header class="relative mb-20 md:mb-32">
            <div class="absolute -top-6 -left-2 font-mono text-zinc-800 text-[10px] tracking-[0.5em] uppercase">
                [ PERSONNEL_DATABASE // 2026_REVISION ]
            </div>
            
            <div class="flex flex-col gap-6">
                <div class="flex items-center gap-4">
                    <span class="h-px w-12 bg-lime-400"></span>
                    <span class="font-mono text-lime-400 text-[10px] uppercase tracking-[0.5em] animate-pulse">
                        Authorized_Access_Only
                    </span>
                </div>
                <Title 
                    class="uppercase font-black italic tracking-tighter text-7xl md:text-[9rem] lg:text-[11rem] leading-[0.75] text-white" 
                    title="Minds_" 
                    subtitle={lang === 'es' ? 'El núcleo del código' : 'The core of the code'} 
                />
            </div>
        </header>

        <div class="mt-12">
            <ol class="flex flex-col border-t border-zinc-900">
                {
                    allAuthors.map((author, index) => {
                        const personnelID = `VNTT-NODE-${(index + 1).toString().padStart(2, '0')}`;
                        
                        return (
                            <li class="group relative border-b border-zinc-900 overflow-hidden">
                                <span class="absolute right-10 top-1/2 -translate-y-1/2 font-mono text-[10vw] font-black text-white/[0.01] pointer-events-none group-hover:text-lime-400/[0.03] transition-colors duration-700 italic select-none">
                                    {personnelID}
                                </span>

                                <a 
                                    href={translatePath(`/authors/${author.slug}`)} 
                                    class="flex w-full items-center justify-between py-12 md:py-20 px-0 group"
                                    data-cursor-hover
                                >
                                    <div class="flex items-center gap-10 md:gap-16">
                                        <div class="relative h-24 w-24 shrink-0 overflow-hidden border border-zinc-800 bg-zinc-900 group-hover:border-lime-400/50 transition-colors duration-500 md:h-36 md:w-36">
                                            {author.data.avatar ? (
                                                <Image 
                                                    src={author.data.avatar} 
                                                    alt={author.data.name}
                                                    width={300}
                                                    height={300}
                                                    class="h-full w-full object-cover grayscale brightness-75 transition-all duration-700 group-hover:grayscale-0 group-hover:scale-105 group-hover:brightness-110"
                                                />
                                            ) : (
                                                <div class="flex h-full w-full items-center justify-center bg-zinc-900 text-zinc-800 text-5xl font-black italic uppercase">
                                                    {author.data.name.charAt(0)}
                                                </div>
                                            )}
                                            <div class="absolute inset-0 bg-lime-400/10 h-1/2 w-full -translate-y-full group-hover:animate-scan pointer-events-none opacity-0 group-hover:opacity-100"></div>
                                        </div>

                                        <div class="flex flex-col gap-4">
                                            <div class="flex flex-col gap-1">
                                                <span class="font-mono text-[9px] text-zinc-600 uppercase tracking-widest group-hover:text-lime-400 transition-colors">
                                                    // {personnelID}
                                                </span>
                                                <h3 class="text-4xl font-black uppercase italic tracking-tighter md:text-7xl lg:text-8xl text-white group-hover:translate-x-4 transition-transform duration-700 ease-out">
                                                    {author.data.name}
                                                </h3>
                                            </div>
                                            <div class="flex items-center gap-4">
                                                <span class="h-px w-6 bg-zinc-800 group-hover:bg-lime-400 transition-colors"></span>
                                                <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-zinc-500 group-hover:text-zinc-300">
                                                    {author.data.role || "Technical Expert"}
                                                </span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="hidden md:flex items-center gap-8 pr-4">
                                        <div class="font-mono text-[9px] text-zinc-800 opacity-0 group-hover:opacity-100 transition-all uppercase tracking-widest">
                                            View_Profile
                                        </div>
                                        <div class="flex h-16 w-16 items-center justify-center rounded-none border border-zinc-900 text-zinc-700 transition-all duration-500 group-hover:border-lime-400 group-hover:text-lime-400 group-hover:bg-lime-400/5 rotate-45 group-hover:rotate-0">
                                            <Icon name="ic:baseline-arrow-right-alt" width="32" height="32" />
                                        </div>
                                    </div>
                                </a>
                                
                                <div class="absolute bottom-0 left-0 h-[2px] w-0 bg-lime-400 transition-all duration-1000 ease-in-out group-hover:w-full shadow-[0_0_10px_#a3e635]"></div>
                            </li>
                        );
                    })
                }
            </ol>
        </div>

        <div class="mt-20 py-8 border-t border-zinc-900 flex justify-between items-center font-mono text-[9px] text-zinc-700 uppercase tracking-[0.4em]">
            <span>End_of_Registry</span>
            <span class="text-zinc-800 animate-pulse">Scanning_Active</span>
        </div>
    </div>
</section>

<style is:global>
    /* Scanline Animation (Industrial Feel) */
    @keyframes scan {
        0% { transform: translateY(-100%); }
        100% { transform: translateY(200%); }
    }
    .animate-scan {
        animation: scan 2s linear infinite;
    }

    /* Industrial Reveal Animation */
    .animate-reveal {
        clip-path: polygon(0 0, 0 0, 0 100%, 0% 100%);
        animation: reveal-industrial 1.4s cubic-bezier(0.19, 1, 0.22, 1) forwards;
    }

    @keyframes reveal-industrial {
        to { clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%); }
    }
</style>