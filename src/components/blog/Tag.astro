---
/* src/components/blog/Tag.astro */
import { type CollectionEntry } from "astro:content";
import Entry from "@/components/blog/Entry.astro"; // Asegúrate de que apunte a tu componente Entry
import { Icon } from "astro-icon/components";

interface Props {
    tag: string;
    posts: CollectionEntry<"posts">[];
}

const { tag, posts } = Astro.props as Props;

// ID de consulta único para la sesión técnica
const queryId = `QRY_${tag.toUpperCase().replace(/\s+/g, '_')}_0x${Math.floor(Math.random() * 1000)}`;
const timestamp = new Date().toLocaleTimeString('en-GB', { hour12: false });
---

<section class="bg-[#050505] min-h-screen text-white relative overflow-hidden selection:bg-lime-400 selection:text-black">
    
    <div class="fixed inset-0 pointer-events-none z-50 overflow-hidden opacity-30">
        <div class="absolute inset-0 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.1)_50%),linear-gradient(90deg,rgba(163,230,53,0.01),rgba(0,0,0,0),rgba(163,230,53,0.01))] bg-[length:100%_4px,4px_100%]"></div>
    </div>

    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" 
         style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 40px 40px;">
    </div>

    <div class="container relative z-10 mx-auto px-6 py-24 md:px-12 lg:pt-32 2xl:max-w-7xl">
        
        <header class="relative border-b border-zinc-900 pb-16 mb-20 group">
            <div class="absolute -top-8 -left-2 font-mono text-zinc-800 text-[10px] tracking-[0.5em] uppercase">
                [ {queryId} // FILTER_STREAM ]
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">
                <div class="lg:col-span-9">
                    <div class="flex items-center gap-4 mb-8">
                        <span class="h-px w-12 bg-lime-400"></span>
                        <span class="font-mono text-lime-400 text-[10px] uppercase tracking-[0.5em] animate-pulse">
                            Records_Found: {posts.length.toString().padStart(2, '0')}
                        </span>
                    </div>

                    <div class="relative">
                        <span class="absolute -left-12 -top-16 text-[18vw] font-black text-white/[0.015] select-none pointer-events-none italic uppercase tracking-tighter">
                            #{tag}
                        </span>
                        
                        <div class="relative z-10 flex flex-col gap-2">
                             <span class="font-mono text-zinc-700 text-[10px] uppercase tracking-widest">Searching_In: /vault/segments/</span>
                             <h1 class="text-7xl md:text-[10vw] font-black text-white uppercase italic tracking-[calc(-0.05em)] leading-[0.75] animate-reveal">
                                {tag}<span class="text-lime-400">_</span>
                            </h1>
                        </div>
                    </div>
                </div>

                <div class="lg:col-span-3 lg:text-right font-mono text-zinc-600 text-[9px] uppercase space-y-2 border-l lg:border-l-0 lg:border-r border-zinc-900 pr-6 pl-6 lg:pl-0">
                    <p>Cluster: NODE_SCL_CONTENT</p>
                    <p>Security: LVL_02_PUBLIC</p>
                    <p class="text-zinc-800">Timestamp: {timestamp}</p>
                </div>
            </div>
        </header>

        {posts.length > 0 ? (
            <div class="relative">
                <div class="absolute -left-6 top-0 h-full w-px bg-gradient-to-b from-lime-400/50 via-zinc-900 to-transparent hidden xl:block"></div>
                
                <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-zinc-900 border border-zinc-900 shadow-2xl">
                    {posts.map((post) => (
                        <li class="bg-[#050505] group/item">
                            <Entry
                                url={"/blog/" + post.slug}
                                title={post.data.title}
                                description={post.data.description}
                                author={post.data.author}
                                pubDate={post.data.pubDate.toLocaleDateString('en-GB', { day: '2-digit', month: '2-digit', year: 'numeric' }).replace(/\//g, '.')}
                                image={post.data.image.source}
                            />
                        </li>
                    ))}
                </ul>
            </div>
        ) : (
            <div class="py-48 flex flex-col items-center justify-center border border-zinc-900 bg-zinc-950/20 relative group">
                <div class="absolute inset-0 bg-red-500/[0.02] opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <Icon name="ri:error-warning-line" class="text-zinc-800 w-16 h-16 mb-8" />
                <div class="font-mono text-red-500/50 text-[10px] uppercase tracking-[0.6em] mb-4">
                    [ FATAL_ERROR: NULL_DATA_STREAM ]
                </div>
                <p class="text-zinc-500 font-light italic text-xl uppercase tracking-widest">No se encontraron registros en este segmento.</p>
                <a href="/labs" class="mt-12 font-mono text-[9px] text-zinc-400 border border-zinc-800 px-6 py-3 hover:bg-white hover:text-black transition-all">
                    >> RETURN_TO_DATABASE
                </a>
            </div>
        )}

        <footer class="mt-24 pt-10 border-t border-zinc-900 flex flex-col md:flex-row justify-between items-center gap-8 font-mono text-[9px] text-zinc-700 uppercase tracking-[0.4em]">
            <div class="flex items-center gap-4">
                <span class="text-lime-400">●</span>
                <span>Query_Status: Successful</span>
                <span class="text-zinc-900">|</span>
                <span>Cache_Hit: True</span>
            </div>
            <div class="flex items-center gap-6">
                <span>VANTTA_LABS_IDX</span>
                <span class="text-zinc-900">//</span>
                <span class="animate-pulse">EndOfStream_</span>
            </div>
        </footer>
    </div>
</section>

<style is:global>
    /* Revelado Industrial */
    .animate-reveal {
        clip-path: polygon(0 0, 0 0, 0 100%, 0% 100%);
        animation: reveal-industrial 1.2s cubic-bezier(0.19, 1, 0.22, 1) forwards;
    }

    @keyframes reveal-industrial {
        to { clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%); }
    }

    /* Grilla de Datos Estricta */
    ul {
        backface-visibility: hidden;
    }

    /* Scrollbar Terminal */
    ::-webkit-scrollbar { width: 3px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #18181b; }
    ::-webkit-scrollbar-thumb:hover { background: #a3e635; }
</style>