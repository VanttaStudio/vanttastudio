---
/* src/components/blog/Author.astro */
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Title from "@components/global/Title.astro";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const { author } = Astro.props;

// ID de personal generado para estética técnica
const personnelID = `VNTT-ID-${author.data.name.slice(0, 3).toUpperCase()}-09`;
---

<section class="relative bg-zinc-950 text-white min-h-screen overflow-hidden selection:bg-lime-400 selection:text-black">
    
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" 
         style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 40px 40px;">
    </div>
    <div class="absolute top-0 left-1/2 w-px h-full bg-zinc-900/50 pointer-events-none"></div>

    <div class="container relative z-10 mx-auto px-6 py-24 md:px-12 lg:pt-32 2xl:max-w-7xl">
        
        <div class="flex flex-col gap-12 lg:flex-row lg:items-end lg:justify-between border-b border-zinc-800 pb-16 relative">
            
            <div class="absolute -top-4 -left-2 font-mono text-zinc-800 text-[10px] tracking-widest uppercase">
                [ {personnelID} // AUTHOR_PROFILE ]
            </div>

            <div class="max-w-4xl">
                <div class="flex items-center gap-3 mb-6">
                    <span class="h-1 w-1 bg-lime-400 animate-ping"></span>
                    <span class="font-mono text-[10px] uppercase tracking-[0.5em] text-lime-400">
                        {author.data.role || "Technical Lead"}
                    </span>
                </div>

                <Title 
                    title={author.data.name} 
                    subtitle={lang === 'es' ? 'Ficha de Personal' : 'Personnel Record'} 
                    class="uppercase font-black italic tracking-tighter text-7xl md:text-[8rem] lg:text-[10rem] leading-[0.8] mb-10" 
                />
                
                {author.data.bio && (
                    <div class="relative pl-8 border-l border-zinc-800">
                        <p class="font-light text-xl leading-relaxed text-zinc-400 md:text-2xl max-w-2xl italic">
                            "{author.data.bio}"
                        </p>
                    </div>
                )}
            </div>

            <div class="flex flex-col items-center lg:items-end gap-8">
                <div class="relative group">
                    <div class="h-56 w-56 overflow-hidden border border-zinc-800 bg-zinc-900 shadow-[0_0_30px_rgba(0,0,0,0.5)] group-hover:border-lime-400/50 transition-colors duration-500">
                        {author.data.avatar ? (
                            <Image 
                                src={author.data.avatar} 
                                alt={author.data.name}
                                width={400}
                                height={400}
                                class="h-full w-full object-cover grayscale brightness-75 group-hover:grayscale-0 group-hover:brightness-110 transition-all duration-700 ease-out"
                            />
                        ) : (
                            <div class="flex h-full w-full items-center justify-center text-8xl font-black text-zinc-800 uppercase italic">
                                {author.data.name.charAt(0)}
                            </div>
                        )}
                        <div class="absolute inset-0 bg-lime-400/10 h-1/2 w-full -translate-y-full group-hover:animate-scan pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    </div>
                    <div class="absolute -bottom-2 -right-2 bg-zinc-950 border border-zinc-800 px-3 py-1 font-mono text-[9px] text-lime-400 flex items-center gap-2">
                        <span class="w-1 h-1 bg-lime-400 rounded-full animate-pulse"></span> ACTIVE_NODE
                    </div>
                </div>

                <div class="flex gap-3">
                    {author.data.twitter && (
                        <a href={author.data.twitter} class="p-4 border border-zinc-900 text-zinc-600 hover:text-lime-400 hover:border-lime-400 transition-all hover:-translate-y-1 bg-zinc-950 shadow-xl" title="Twitter/X">
                            <Icon name="ri:twitter-x-fill" width="18" />
                        </a>
                    )}
                    {author.data.linkedin && (
                        <a href={author.data.linkedin} class="p-4 border border-zinc-900 text-zinc-600 hover:text-lime-400 hover:border-lime-400 transition-all hover:-translate-y-1 bg-zinc-950 shadow-xl" title="LinkedIn">
                            <Icon name="ri:linkedin-fill" width="18" />
                        </a>
                    )}
                    {author.data.github && (
                        <a href={author.data.github} class="p-4 border border-zinc-900 text-zinc-600 hover:text-lime-400 hover:border-lime-400 transition-all hover:-translate-y-1 bg-zinc-950 shadow-xl" title="GitHub">
                            <Icon name="ri:github-fill" width="18" />
                        </a>
                    )}
                </div>
            </div>
        </div>

        <div class="mt-32">
             <div class="flex items-center gap-6 mb-16">
                <span class="font-mono text-zinc-800 text-[10px] tracking-widest">[ HIST_LOG_01 ]</span>
                <h2 class="font-black text-3xl md:text-4xl uppercase italic tracking-tighter">
                    {lang === 'es' ? 'Publicaciones Recientes' : 'Recent Outputs'}
                </h2>
                <div class="h-px flex-1 bg-zinc-900"></div>
            </div>
            
            <div class="reveal-container">
                <slot /> 
            </div>
        </div>

    </div>
</section>

<style is:global>
    /* Animación del escáner técnico */
    @keyframes scan {
        0% { transform: translateY(-100%); }
        100% { transform: translateY(200%); }
    }
    .animate-scan {
        animation: scan 2s linear infinite;
    }

    /* Animación de entrada industrial */
    section {
        animation: revealSection 1s cubic-bezier(0.19, 1, 0.22, 1) forwards;
    }

    @keyframes revealSection {
        from { opacity: 0; clip-path: inset(0 100% 0 0); }
        to { opacity: 1; clip-path: inset(0 0 0 0); }
    }

    .reveal-container {
        animation: fadeInUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
    }

    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>