---
import Newsletter from "@components/blog/Newsletter.astro";
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@i18n/utils";
import logovanta from "@/assets/images/logovanta.png";
import { Image } from "astro:assets";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<footer class="section relative w-full bg-zinc-950 text-white overflow-hidden border-t border-zinc-900">
    <div class="mx-auto w-full max-w-[1400px] px-6 lg:px-12 py-12 lg:py-24 flex flex-col gap-20">
        
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
            
            <div class="lg:col-span-8 grid grid-cols-2 md:grid-cols-2 gap-10">
                
                <div class="flex flex-col gap-6">
                    <p class="text-zinc-500 text-xs font-mono uppercase tracking-[0.2em]">Social</p>
                    <div class="flex flex-col gap-3">
                        <a href="https://twitter.com/vanttastudio" target="_blank" class="hover:text-lime-400 transition-colors w-fit text-lg font-medium">Twitter / X</a>
                        <a href="https://www.instagram.com/vanttastudio" target="_blank" class="hover:text-lime-400 transition-colors w-fit text-lg font-medium">Instagram</a>
                        <a href="https://www.linkedin.com/company/vantta" target="_blank" class="hover:text-lime-400 transition-colors w-fit text-lg font-medium">Linkedin</a>
                    </div>
                </div>

                <div class="flex flex-col gap-6">
                    <p class="text-zinc-500 text-xs font-mono uppercase tracking-[0.2em]">Sitemap</p>
                    <div class="flex flex-col gap-3">
                        <a href={translatePath("/")} class="hover:text-lime-400 transition-colors w-fit text-base">Inicio</a>
                        <a href={translatePath("/work/")} class="hover:text-lime-400 transition-colors w-fit text-base">Proyectos</a>
                        <a href={translatePath("/blog/")} class="hover:text-lime-400 transition-colors w-fit text-base">Labs</a>
                        <a href={translatePath("/contact/")} class="hover:text-lime-400 transition-colors w-fit text-base">{t("contacts")}</a>
                    </div>
                </div>

                <div class="col-span-2 mt-8">
                    <p class="text-zinc-500 text-xs font-mono uppercase tracking-[0.2em] mb-4">Contact</p>
                    <a href="mailto:vanttastudio@gmail.com" class="text-2xl md:text-3xl lg:text-4xl font-bold hover:text-lime-400 transition-colors break-all">
                        vanttastudio@gmail.com
                    </a>
                </div>
            </div>

            <div class="lg:col-span-4 flex flex-col gap-8">
                <div class="text-3xl lg:text-5xl font-black leading-none uppercase italic">
                    <span class="text-lime-400 block">{t("footer.newsletter") || "Stay"}</span>
                    <span class="block text-zinc-800">{t("footer.newsletter2") || "Updated"}</span>
                </div>
                <Newsletter />
            </div>
        </div>

        <div class="flex flex-col md:flex-row items-end justify-between gap-8 pt-8 border-t border-zinc-900">
            
            <div class="flex flex-col gap-6 w-full md:w-auto">
                <div class="w-32 opacity-50 hover:opacity-100 transition-opacity duration-500">
                    <Image 
                        src={logovanta} 
                        alt="Vantta Studio" 
                        class="h-auto w-full filter brightness-0 invert" 
                    />
                </div>
                <div class="text-xs text-zinc-500 font-mono">
                    <p class="uppercase tracking-widest text-zinc-300 mb-1">Vantta Studio</p>
                    <p>© {new Date().getFullYear()} — All rights reserved.</p>
                </div>
            </div>

            <button
                id="go-top-button"
                aria-label="Go to Top"
                class="group relative flex items-center justify-center w-16 h-16 rounded-full border border-zinc-800 bg-zinc-950 hover:bg-lime-400 hover:border-lime-400 transition-colors duration-300"
                data-cursor-hover>
                <svg 
                    xmlns="http://www.w3.org/2000/svg" 
                    width="24" height="24" 
                    viewBox="0 0 24 24"
                    class="text-white group-hover:text-black transition-colors duration-300 relative z-10"
                >
                    <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m17 11l-5-5m0 0l-5 5m5-5v12"></path>
                </svg>
            </button>
        </div>
    </div>
</footer>

<script>
    import { gsap } from "gsap";

    function initFooter() {
        const goTopButton = document.getElementById("go-top-button");

        if (!goTopButton) return;

        // 1. Lógica de Scroll usando LENIS (Importante)
        goTopButton.onclick = (e) => {
            e.preventDefault();
            // Verificamos si Lenis está activo globalmente
            if (window.lenis) {
                window.lenis.scrollTo(0, { duration: 1.5 });
            } else {
                window.scrollTo({ top: 0, behavior: "smooth" });
            }
        };
        
        // 2. Efecto Magnético (GSAP)
        goTopButton.onmousemove = (e) => {
            const { clientX, clientY } = e;
            const { left, top, width, height } = goTopButton.getBoundingClientRect();
            
            // Calculamos la distancia desde el centro del botón
            const x = (clientX - (left + width / 2)) * 0.4; // 0.4 es la intensidad
            const y = (clientY - (top + height / 2)) * 0.4;

            gsap.to(goTopButton, { 
                x: x, 
                y: y, 
                duration: 0.3, 
                ease: "power2.out" 
            });
        };

        // 3. Reset al salir del botón
        goTopButton.onmouseleave = () => {
            gsap.to(goTopButton, { 
                x: 0, 
                y: 0, 
                duration: 0.6, 
                ease: "elastic.out(1, 0.4)" 
            });
        };
    }

    // Ejecutar en cada navegación de Astro
    document.addEventListener("astro:page-load", initFooter);
</script>