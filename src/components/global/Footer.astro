---
/* src/components/global/Footer.astro */
---

<footer class="w-full bg-[#050505] pt-32 pb-20 border-t border-zinc-900/30">
    <div class="max-w-[1440px] mx-auto px-6 flex flex-col items-center text-center">
        
        <div class="flex items-center gap-8 mb-10">
            <a href="https://instagram.com/vanttacode.cl" target="_blank" class="text-zinc-600 hover:text-white transition-colors" aria-label="Instagram">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
            <a href="https://facebook.com/Vanttacode" target="_blank" class="text-zinc-600 hover:text-white transition-colors" aria-label="Facebook">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            </a>
        </div>

        <div class="flex flex-col gap-2">
            <p class="font-mono text-[10px] md:text-xs text-zinc-600 uppercase tracking-[0.2em]">
                © 2026 VANTTA.CODE // PUNTA ARENAS, CHILE.
            </p>
            
            <p class="font-mono text-[10px] md:text-xs text-zinc-700 uppercase tracking-[0.1em]">
                Designed by <span class="text-white font-bold italic tracking-tighter">VANTTA.CODE</span>
            </p>
        </div>

    </div>
</footer>

<style>
    footer {
        /* Eliminamos cualquier comportamiento de cursor especial para mantenerlo nativo */
        cursor: auto !important;
    }
</style>