<script>
    import Lenis from 'lenis';
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    // 1. Tipado correcto para evitar errores de 'any' implícito
    let lenis: Lenis | undefined;
    let rafUpdate: (time: number) => void;

    function initSmoothScroll() {
        // 2. LIMPIEZA TOTAL: Evita la vibración por acumulación de instancias
        if (lenis) {
            lenis.destroy();
            if (rafUpdate) gsap.ticker.remove(rafUpdate);
        }

        // 3. Inicialización de Lenis
        lenis = new Lenis({
            duration: 1.2,
            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            orientation: 'vertical', 
            gestureOrientation: 'vertical',
            smoothWheel: true,
            wheelMultiplier: 1,
            touchMultiplier: 2,
        });

        // 4. Sincronización con ScrollTrigger
        lenis.on('scroll', ScrollTrigger.update);

        // 5. Definición del Loop unificado para el ticker de GSAP
        rafUpdate = (time: number) => {
            lenis?.raf(time * 1000);
        };

        gsap.ticker.add(rafUpdate);
        gsap.ticker.lagSmoothing(0);

        // 6. Exponer Lenis globalmente con tipado seguro
        // Esto permite que el Footer lo use como window.lenis.scrollTo()
        (window as any).lenis = lenis;
        
        console.log("🌊 Smooth Scroll (Lenis) Sincronizado");
    }

    // Eventos de Astro para View Transitions
    document.addEventListener("astro:page-load", initSmoothScroll);

    // Limpieza antes de cambiar de página para evitar fugas de memoria
    document.addEventListener("astro:before-swap", () => {
        if (lenis) {
            lenis.destroy();
            if (rafUpdate) gsap.ticker.remove(rafUpdate);
        }
    });
</script>