---
/* src/components/global/LinkBlend.astro */
interface Props {
    class?: string;
    isButton?: boolean;
    href?: string;
    type?: "button" | "submit" | "reset";
    [x: string]: any; 
}

const { class: className, isButton, ...rest } = Astro.props;
---

{
    isButton ? (
        <button class:list={["link-blend-element", className]} {...rest}>
            <span class="content-wrapper"><slot /></span>
        </button>
    ) : (
        <a class:list={["link-blend-element", className]} {...rest}>
            <span class="content-wrapper"><slot /></span>
        </a>
    )
}

<style>
    .link-blend-element {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 28px;
        overflow: hidden;
        cursor: pointer;
        
        /* Tipografía Industrial */
        font-family: 'Inter', sans-serif;
        font-weight: 900;
        font-style: italic;
        text-transform: uppercase;
        letter-spacing: -0.05em;
        font-size: 14px;
        text-decoration: none;
        
        /* Colores Base */
        color: #FFFFFF;
        background: transparent;
        border: 1px solid #27272a; /* Zinc-800 */
        transition: color 0.2s ease, border-color 0.2s ease;
    }

    /* Bloque de Fondo Sólido (Efecto de Inversión) */
    .link-blend-element::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #FFFFFF;
        transform: translateY(101%); /* Inicia oculto abajo */
        transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        z-index: 1;
    }

    .content-wrapper {
        position: relative;
        z-index: 10;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* ESTADO HOVER: Inversión instantánea */
    .link-blend-element:hover {
        color: #050505; /* Negro sobre Blanco */
        border-color: #FFFFFF;
    }

    .link-blend-element:hover::before {
        transform: translateY(0);
    }

    /* Soporte para Mobile (Touch) */
    @media (max-width: 768px) {
        .link-blend-element {
            padding: 10px 20px;
            font-size: 12px;
        }
    }
</style>