---
/* src/pages/branding.astro */
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";
import UbikappPromo from "@/components/ubikapp/UbikappPromo.tsx";
import Cta from "@/components/landing/Cta.tsx";

const seo: AstroSeoProps = {
    title: "VANTTA // DISEÑO_Y_MARCA",
    description: "Diseño de marcas y estrategias para vender más. Logos, Redes Sociales y Publicidad.",
    canonical: "https://vanttacode.cl/branding/",
};

const brandingServices = [
    { id: "_01", title: "Diseño de Logo", price: "$350.000", desc: "Creamos la imagen principal de tu empresa. Incluye logo, colores y letras para que todo se vea profesional.", features: ["Logo en todos los formatos", "Guía de colores", "Tipografías"] },
    { id: "_02", title: "Anuncios (Ads)", price: "$200.000", desc: "Diseño de imágenes y videos para vender por Instagram, Facebook y Google. Enfocado en atraer clientes.", features: ["Imágenes para anuncios", "Videos cortos", "Textos para vender"] },
    { id: "_03", title: "Manejo de Redes", price: "$450.000", desc: "Nos encargamos de tus redes sociales. Publicamos contenido y respondemos mensajes para que tú vendas.", features: ["Publicaciones diarias", "Respuesta a clientes", "Estrategia mensual"] },
    { id: "_04", title: "Nombre (Naming)", price: "$150.000", desc: "Buscamos el nombre ideal para tu negocio. Que sea fácil de recordar y que el dominio esté disponible.", features: ["Búsqueda de nombres", "Dominio .cl / .com", "Revisión legal"] },
    { id: "_05", title: "Cajas y Empaques", price: "$280.000", desc: "Diseñamos el envoltorio de tus productos. Desde etiquetas hasta cajas que destaquen en la repisa.", features: ["Diseño de etiquetas", "Cajas a medida", "Manual de impresión"] },
    { id: "_06", title: "Catálogos Pro", price: "$220.000", desc: "Revistas y presentaciones digitales para mostrar tus productos de forma ordenada y atractiva.", features: ["Catálogo digital", "Fichas técnicas", "PDF interactivo"] },
    { id: "_07", title: "Nueva Imagen", price: "Cotizar", desc: "¿Tu logo quedó viejo? Lo actualizamos para que se vea moderno sin perder la confianza de tus clientes.", features: ["Auditoría de imagen", "Rediseño de logo", "Actualización total"] },
    { id: "_08", title: "Papelería", price: "$120.000", desc: "Todo lo necesario para el día a día: tarjetas de presentación, hojas con logo y firmas para tu email.", features: ["Tarjetas", "Hojas membrete", "Firma de correo"] },
];
---

<BaseLayout seo={seo}>
    <main class="bg-[#050505] text-white min-h-screen relative overflow-hidden selection:bg-white selection:text-black">
        
        <div class="absolute inset-0 opacity-[0.02] pointer-events-none"
             style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 40px 40px;">
        </div>

        <section class="relative z-10 mx-auto px-6 pt-40 pb-24 md:px-12 max-w-[1440px]">
            <div class="max-w-6xl border-l-2 border-white pl-8 md:pl-12">
                <div class="flex flex-col gap-6 mb-12">
                    <span class="font-mono text-zinc-600 text-[10px] uppercase tracking-[0.5em] font-black">
                        DISEÑO // VENTAS // 2026
                    </span>
                    <h1 class="text-6xl md:text-8xl lg:text-[10rem] font-black uppercase tracking-tighter italic leading-[0.75] text-white">
                        MARCAS QUE <br/> <span class="text-zinc-900 outline-text">VENDEN_</span>
                    </h1>
                </div>
                <p class="font-mono text-zinc-500 text-[11px] md:text-sm uppercase tracking-[0.3em] leading-relaxed max-w-xl">
                    No solo hacemos dibujos bonitos. Creamos la <span class="text-white">identidad visual</span> que tu negocio necesita para atraer clientes y ganar confianza.
                </p>
            </div>
        </section>

        <section class="relative z-10 border-y border-zinc-900 bg-black/20">
            <div class="mx-auto max-w-[1440px] px-0 md:px-12 py-24">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 border-t border-l border-zinc-900">
                    {brandingServices.map(item => (
                        <div class="p-10 border-r border-b border-zinc-900 hover:bg-zinc-950 transition-all duration-700 group flex flex-col justify-between relative">
                            <span class="absolute top-6 right-8 font-mono text-[10px] text-zinc-800 group-hover:text-white transition-colors uppercase tracking-widest">{item.id}</span>
                            <div>
                                <h3 class="text-2xl font-black uppercase italic mb-1 tracking-tighter text-white group-hover:translate-x-1 transition-transform">{item.title}</h3>
                                <p class="text-zinc-700 font-mono text-[9px] mb-8 uppercase tracking-widest font-black">VALOR_ {item.price}</p>
                                <p class="text-zinc-500 text-[10px] uppercase font-mono leading-relaxed mb-10 group-hover:text-zinc-300 transition-colors">{item.desc}</p>
                            </div>
                            <ul class="space-y-3 pt-6 border-t border-zinc-900">
                                {item.features.map(feat => (
                                    <li class="text-[9px] text-zinc-700 font-mono uppercase tracking-widest flex items-center gap-3 group-hover:text-white transition-colors">
                                        <div class="w-1 h-1 bg-zinc-800 group-hover:bg-white transition-colors"></div> {feat}
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <section class="relative z-10 py-32 bg-white text-black">
            <div class="mx-auto px-6 md:px-12 max-w-[1440px]">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-24 gap-12">
                    <div class="border-l-4 border-black pl-8">
                        <h3 class="text-6xl md:text-8xl lg:text-9xl font-black uppercase italic tracking-tighter leading-[0.8]">CRECE EN<br/>REDES.</h3>
                        <p class="text-zinc-400 uppercase font-mono text-[10px] tracking-[0.4em] mt-8 font-black">ADMINISTRACIÓN_MENSUAL_DE_REDES</p>
                    </div>
                    <div class="bg-black text-white p-10 md:p-14">
                        <p class="text-[10px] font-mono uppercase tracking-[0.4em] text-zinc-500 mb-4">INVERSIÓN_MENSUAL</p>
                        <p class="text-5xl md:text-7xl font-black italic tracking-tighter">$450.000 <span class="text-sm font-mono opacity-30">/ MES</span></p>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-24 border-t border-zinc-100 pt-20">
                    {[
                        { num: "01", title: "CONTENIDO", desc: "Creamos fotos y videos reales para que tus redes no parezcan vacías y atraigan gente." },
                        { num: "02", title: "PUBLICIDAD", desc: "Invertimos tu presupuesto en anuncios para que lleguen personas interesadas en comprar." },
                        { num: "03", title: "RESULTADOS", desc: "Te mostramos cuánta gente llegó y qué funcionó. Menos charla, más ventas." }
                    ].map(step => (
                        <div class="group">
                            <span class="text-black font-black text-3xl md:text-4xl italic block mb-6 group-hover:translate-x-2 transition-transform">{step.num} // {step.title}</span>
                            <p class="text-[11px] font-mono uppercase tracking-widest text-zinc-500 leading-loose border-l border-zinc-200 pl-8">{step.desc}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <div class="relative z-10 bg-[#050505]">
            <UbikappPromo client:visible />
            <div class="pb-20">
                <Cta client:visible />
            </div>
        </div>

    </main>

    <style is:global>
        .outline-text {
            -webkit-text-stroke: 1px rgba(255, 255, 255, 0.1);
            color: transparent;
        }
    </style>
</BaseLayout>