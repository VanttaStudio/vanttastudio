---
/* src/pages/sales-strategy.astro */
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";
import UbikappPromo from "@/components/ubikapp/UbikappPromo.tsx";
import Cta from "@/components/landing/Cta.tsx";

const seo: AstroSeoProps = {
    title: "VANTTA // ESTRATEGIA_DE_VENTAS",
    description: "Entrenamiento y estrategias directas para aumentar las ventas de tu empresa.",
    canonical: "https://vanttacode.cl/services/sales-strategy/",
};

const performanceServices = [
    { id: "_01", title: "Taller de Cierre", price: "$450.000", desc: "Entrenamiento práctico para que tu equipo aprenda a cerrar ventas y manejar objeciones sin miedo.", features: ["Técnicas de cierre", "Práctica real", "Manejo de objeciones"] },
    { id: "_02", title: "Charlas de Equipo", price: "$300.000", desc: "Sesiones motivacionales y técnicas para alinear a todos con las metas de venta de la empresa.", features: ["Motivación grupal", "Metas claras", "Cultura de trabajo"] },
    { id: "_03", title: "Retiro de Ventas", price: "Cotizar", desc: "Jornada intensiva fuera de la oficina para planificar el año y fortalecer la unión del equipo.", features: ["Plan de trabajo", "Liderazgo", "Unión de equipo"] },
    { id: "_04", title: "Plan de Marketing", price: "$500.000", desc: "Armamos la estrategia completa para que tu marca se vea mejor que la competencia y venda más.", features: ["Análisis de mercado", "Plan de anuncios", "Imagen de marca"] },
    { id: "_05", title: "Gestión de Personal", price: "$350.000", desc: "Ayudamos a mejorar el ambiente de trabajo para que tus vendedores sean más felices y produzcan más.", features: ["Clima laboral", "Solución de problemas", "Productividad"] },
    { id: "_06", title: "Asesoría Directa", price: "$120.000", desc: "Reunión privada para revisar tu negocio, encontrar errores y darte soluciones inmediatas para crecer.", features: ["Revisión de números", "Plan de acción", "Consultas directas"] },
    { id: "_07", title: "Productividad", price: "$250.000", desc: "Sistemas y consejos prácticos para que tu equipo trabaje mejor, pierda menos tiempo y logre más.", features: ["Uso del tiempo", "Herramientas digitales", "Orden de trabajo"] },
    { id: "_08", title: "Ventas a Empresas", price: "$400.000", desc: "Estrategias específicas para vender productos caros o servicios a otras empresas (B2B).", features: ["Ventas grandes", "Captación de clientes", "Cierre corporativo"] },
];
---

<BaseLayout seo={seo}>
    <main class="bg-[#050505] text-white min-h-screen relative overflow-hidden selection:bg-white selection:text-black">
        
        <div class="absolute inset-0 opacity-[0.02] pointer-events-none z-0"
             style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 40px 40px;">
        </div>

        <section class="relative z-10 mx-auto px-6 pt-40 pb-24 md:px-12 max-w-[1440px]">
            <div class="max-w-6xl border-l-2 border-white pl-8 md:pl-12">
                <div class="flex flex-col gap-6 mb-12">
                    <span class="font-mono text-zinc-600 text-[10px] uppercase tracking-[0.5em] font-black">
                        VENTAS // RESULTADOS // 2026
                    </span>
                    <h1 class="text-6xl md:text-8xl lg:text-[10rem] font-black uppercase tracking-tighter italic leading-[0.75] text-white">
                        SISTEMAS PARA <br/> <span class="text-zinc-900 outline-text">VENDER MÁS_</span>
                    </h1>
                </div>
                <p class="font-mono text-zinc-500 text-[11px] md:text-sm uppercase tracking-[0.3em] leading-relaxed max-w-xl">
                    Entrenamos a tu equipo y optimizamos tus procesos para <span class="text-white">aumentar tus ingresos reales</span>. Menos teoría y más resultados para tu negocio.
                </p>
            </div>
        </section>

        <section class="relative z-10 border-y border-zinc-900 bg-black/20">
            <div class="mx-auto max-w-[1440px] px-0 md:px-12 py-24">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 border-t border-l border-zinc-900">
                    {performanceServices.map(item => (
                        <div class="p-10 border-r border-b border-zinc-900 hover:bg-zinc-950 transition-all duration-700 group flex flex-col justify-between relative">
                            <span class="absolute top-6 right-8 font-mono text-[10px] text-zinc-800 group-hover:text-white transition-colors uppercase tracking-widest">{item.id}</span>
                            <div>
                                <h3 class="text-2xl font-black uppercase italic mb-1 tracking-tighter text-white group-hover:translate-x-1 transition-transform">{item.title}</h3>
                                <p class="text-zinc-700 font-mono text-[9px] mb-8 uppercase tracking-widest font-black">VALOR_ {item.price}</p>
                                <p class="text-zinc-500 text-[10px] uppercase font-mono leading-relaxed mb-10 group-hover:text-zinc-300 transition-colors">{item.desc}</p>
                            </div>
                            <ul class="space-y-3 pt-6 border-t border-zinc-900">
                                {item.features.map(feat => (
                                    <li class="text-[9px] text-zinc-700 font-mono uppercase tracking-widest flex items-center gap-3 group-hover:text-white transition-colors">
                                        <div class="w-1 h-1 bg-zinc-800 group-hover:bg-white transition-colors"></div> {feat}
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <section class="relative z-10 mx-auto px-6 py-32 md:px-12 max-w-[1440px]">
            <div class="grid grid-cols-1 lg:grid-cols-2 border border-zinc-900 overflow-hidden">
                <div class="group relative overflow-hidden bg-[#050505] p-12 lg:p-24 border-b lg:border-b-0 lg:border-r border-zinc-900">
                    <span class="text-zinc-600 font-mono text-[10px] uppercase tracking-[0.5em] mb-6 block">EQUIPO_Y_VENTAS</span>
                    <h2 class="text-5xl md:text-7xl font-black uppercase italic tracking-tighter leading-none mb-8">EQUIPOS QUE<br/>PRODUCEN.</h2>
                    <p class="text-zinc-500 font-mono text-sm uppercase tracking-tight leading-relaxed max-w-md group-hover:text-zinc-300 transition-colors">
                        Ayudamos a tus vendedores a eliminar bloqueos y trabajar con una meta clara. Un equipo bien organizado vende mucho más.
                    </p>
                </div>

                <div class="bg-white p-12 lg:p-24 flex flex-col justify-center relative group text-black">
                    <span class="text-zinc-400 font-mono text-[10px] uppercase tracking-[0.5em] mb-6 block">ENTRENAMIENTO_VANTTA</span>
                    <h2 class="text-5xl md:text-7xl font-black uppercase italic tracking-tighter leading-none mb-8">TALLERES DE<br/>ALTO NIVEL_</h2>
                    <p class="text-zinc-500 font-mono text-sm uppercase tracking-tight leading-relaxed font-bold mb-12">
                        Sesiones de trabajo real para dueños de empresas y equipos comerciales que quieren dominar su mercado.
                    </p>
                    <a href="https://wa.me/56966877441" class="inline-block border-2 border-black px-10 py-4 text-[11px] font-mono uppercase tracking-[0.3em] font-black hover:bg-black hover:text-white transition-all text-center">
                        SOLICITAR_REUNIÓN
                    </a>
                </div>
            </div>
        </section>

        <section class="relative z-10 bg-white text-black py-32 border-y border-zinc-200">
            <div class="mx-auto px-6 md:px-12 max-w-[1440px] grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
                <div class="border-l-4 border-black pl-8">
                    <h3 class="text-6xl md:text-8xl lg:text-9xl font-black uppercase italic tracking-tighter leading-[0.85]">TU PLAN<br/>DE VENTA.</h3>
                    <p class="text-zinc-400 uppercase font-mono text-[10px] tracking-[0.4em] mt-10 font-black italic">AUMENTA_TUS_INGRESOS_REALES</p>
                </div>
                <div class="space-y-20">
                    {[
                        { num: "01", title: "Auditoría de Ventas", desc: "Revisamos cómo estás vendiendo hoy para encontrar los puntos donde estás perdiendo dinero." },
                        { num: "02", title: "Plan de Acción", desc: "Creamos la estrategia y entrenamos a tu equipo en técnicas de persuasión y cierre de negocios." },
                        { num: "03", title: "Resultados Reales", desc: "Medimos el crecimiento y ajustamos el plan para que tus ventas sigan subiendo constantemente." }
                    ].map(step => (
                        <div class="flex gap-10 items-start group">
                            <span class="text-6xl font-black italic text-zinc-100 group-hover:text-black transition-colors">{step.num}</span>
                            <div class="border-l border-zinc-200 pl-10">
                                <h4 class="font-black uppercase text-3xl italic tracking-tighter">{step.title}_</h4>
                                <p class="text-[11px] font-mono text-zinc-500 uppercase tracking-[0.2em] mt-4 leading-relaxed">{step.desc}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <div class="relative z-10 bg-[#050505]">
            <UbikappPromo client:visible />
            <div class="pb-20">
                <Cta client:visible />
            </div>
        </div>

    </main>

    <style is:global>
        .outline-text {
            -webkit-text-stroke: 1px rgba(255, 255, 255, 0.1);
            color: transparent;
        }
    </style>
</BaseLayout>