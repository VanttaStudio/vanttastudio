---
/* src/pages/web-development.astro */
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";
import UbikappPromo from "@/components/ubikapp/UbikappPromo.tsx";
import Cta from "@/components/landing/Cta.tsx";

const seo: AstroSeoProps = {
    title: "VANTTA // DESARROLLO_WEB",
    description: "Páginas web rápidas y sistemas de venta online. Diseño profesional enfocado en atraer clientes.",
    canonical: "https://vanttacode.cl/services/web-development/",
};

const solutions = [
    { id: "_01", title: "Páginas de Venta", price: "Desde $150.000", desc: "Diseñadas para que el cliente llegue y compre. Ideales para campañas de publicidad.", features: ["Carga instantánea", "Botón a WhatsApp", "Diseño móvil"] },
    { id: "_02", title: "Tiendas Online", price: "Desde $350.000", desc: "Vende tus productos 24/7. Carrito de compras fácil de usar y sin comisiones extras.", features: ["Pagos con tarjetas", "Gestión de stock", "Fácil de administrar"] },
    { id: "_03", title: "Web Empresa", price: "Desde $250.000", desc: "Presencia profesional para tu negocio. Dale confianza a tus clientes con un sitio de alto nivel.", features: ["Secciones ilimitadas", "Google Maps / SEO", "Correos corporativos"] },
    { id: "_04", title: "Menú Digital Pro", price: "Desde $280.000", desc: "Especial para restoranes. Los clientes piden desde la mesa o desde su casa sin errores.", features: ["Código QR", "Panel de pedidos", "Cambios en tiempo real"] },
    { id: "_05", title: "Sistemas Internos", price: "Desde $450.000", desc: "Software para organizar tu administración, inventarios o personal desde la web.", features: ["Control de acceso", "Base de datos", "Reportes en vivo"] },
    { id: "_06", title: "Chatbots con IA", price: "Desde $180.000", desc: "Un asistente inteligente que responde dudas de tus clientes incluso cuando tú duermes.", features: ["Respuestas rápidas", "Captación de datos", "Atención 24/7"] },
    { id: "_07", title: "Web Inmobiliaria", price: "Desde $400.000", desc: "Catálogo de propiedades profesional con buscador avanzado y fichas técnicas.", features: ["Buscador de casas", "Fotos y videos", "Contacto directo"] },
    { id: "_08", title: "Software en Nube", price: "Cotizar", desc: "Sistemas complejos para necesidades únicas. Si lo puedes imaginar, lo programamos.", features: ["Código propio", "Seguridad total", "Escalable"] },
];
---

<BaseLayout seo={seo}>
    <main class="bg-[#050505] text-white min-h-screen relative overflow-hidden selection:bg-white selection:text-black">
        
        <div class="absolute inset-0 opacity-[0.02] pointer-events-none z-0"
             style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 40px 40px;">
        </div>

        <section class="relative z-10 mx-auto px-6 pt-40 pb-24 md:px-12 max-w-[1440px]">
            <div class="max-w-6xl border-l-2 border-white pl-8 md:pl-12">
                <div class="flex flex-col gap-6 mb-12">
                    <span class="font-mono text-zinc-600 text-[10px] uppercase tracking-[0.5em] font-black">
                        WEB_DEVELOPMENT // 2026
                    </span>
                    <h1 class="text-6xl md:text-8xl lg:text-[10rem] font-black uppercase tracking-tighter italic leading-[0.75] text-white">
                        DESARROLLO <br/> <span class="text-zinc-900 outline-text">WEB_</span>
                    </h1>
                </div>
                <p class="font-mono text-zinc-500 text-[11px] md:text-sm uppercase tracking-[0.3em] leading-relaxed max-w-xl">
                    Creamos sitios web que cargan en menos de un segundo. <span class="text-white">Sin cuotas mensuales</span> por plataforma. El código es tuyo para siempre.
                </p>
            </div>
        </section>

        <section class="relative z-10 border-y border-zinc-900 bg-black/20">
            <div class="mx-auto max-w-[1440px] px-0 md:px-12 py-24">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 border-t border-l border-zinc-900">
                    {solutions.map(item => (
                        <div class="p-10 border-r border-b border-zinc-900 hover:bg-zinc-950 transition-all duration-700 group flex flex-col justify-between relative">
                            <span class="absolute top-6 right-8 font-mono text-[10px] text-zinc-800 group-hover:text-white transition-colors uppercase tracking-widest">{item.id}</span>
                            <div>
                                <h3 class="text-2xl font-black uppercase italic mb-1 tracking-tighter text-white group-hover:translate-x-1 transition-transform">{item.title}</h3>
                                <p class="text-zinc-700 font-mono text-[9px] mb-8 uppercase tracking-widest font-black">VALOR_ {item.price}</p>
                                <p class="text-zinc-500 text-[10px] uppercase font-mono leading-relaxed mb-10 group-hover:text-zinc-300 transition-colors">{item.desc}</p>
                            </div>
                            <ul class="space-y-3 pt-6 border-t border-zinc-900">
                                {item.features.map(feat => (
                                    <li class="text-[9px] text-zinc-700 font-mono uppercase tracking-widest flex items-center gap-3 group-hover:text-white transition-colors">
                                        <div class="w-1 h-1 bg-zinc-800 group-hover:bg-white transition-colors"></div> {feat}
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <section class="relative z-10 mx-auto px-6 py-32 md:px-12 max-w-[1440px]">
            <div class="grid grid-cols-1 lg:grid-cols-2 border border-zinc-900 overflow-hidden bg-zinc-950">
                <div class="p-12 lg:p-24 border-b lg:border-b-0 lg:border-r border-zinc-900 flex flex-col justify-center relative group">
                    <span class="text-zinc-600 font-mono text-[10px] uppercase tracking-[0.5em] mb-6 block">PROPIEDAD_TOTAL</span>
                    <h2 class="text-5xl md:text-7xl font-black uppercase italic tracking-tighter leading-none mb-8">ERES DUEÑO<br/>DEL CÓDIGO.</h2>
                    <p class="text-zinc-500 font-mono text-sm uppercase tracking-tight leading-relaxed max-w-md group-hover:text-zinc-300 transition-colors">
                        A diferencia de otras agencias, aquí no pagas arriendos mensuales por tu web. Te entregamos el código para que seas 100% independiente.
                    </p>
                </div>

                <div class="bg-white p-12 lg:p-24 flex flex-col justify-center relative group text-black">
                    <div class="space-y-12">
                        <div class="border-b border-zinc-100 pb-8">
                            <span class="text-zinc-400 font-mono text-[10px] uppercase tracking-[0.5em] mb-4 block">CONTROL_PRO</span>
                            <h2 class="text-3xl md:text-4xl font-black uppercase italic tracking-tighter leading-none mb-4">PANELES FÁCILES_</h2>
                            <p class="text-zinc-500 font-mono text-sm uppercase tracking-tight leading-relaxed font-bold">
                                Administra tus productos y fotos sin complicaciones. Hacemos que manejar tu web sea tan simple como enviar un mensaje.
                            </p>
                        </div>
                        <div class="pt-4">
                            <span class="text-zinc-400 font-mono text-[10px] uppercase tracking-[0.5em] mb-4 block">FUTURO_IA</span>
                            <h2 class="text-3xl md:text-4xl font-black uppercase italic tracking-tighter leading-none mb-4">ATENCIÓN CON IA_</h2>
                            <p class="text-zinc-500 font-mono text-sm uppercase tracking-tight leading-relaxed font-bold">
                                Integramos asistentes inteligentes que responden dudas de clientes las 24 horas del día, mejorando tus cierres de venta.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="relative z-10 bg-white text-black py-32 border-y border-zinc-200">
            <div class="mx-auto px-6 md:px-12 max-w-[1440px] grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
                <div class="border-l-4 border-black pl-8">
                    <h3 class="text-6xl md:text-8xl lg:text-9xl font-black uppercase italic tracking-tighter leading-[0.85]">SOPORTE<br/>WEB.</h3>
                    <p class="text-zinc-400 uppercase font-mono text-[10px] tracking-[0.4em] mt-10 font-black italic">ESTABILIDAD_Y_VELOCIDAD</p>
                </div>
                <div class="space-y-16">
                    <div class="group border-b border-zinc-100 pb-10 flex justify-between items-end">
                        <div>
                            <p class="font-mono text-[11px] text-zinc-400 uppercase tracking-[0.2em] mb-4 italic">Cuidado mensual del sitio</p>
                            <h4 class="text-4xl font-black italic uppercase tracking-tighter group-hover:translate-x-2 transition-transform">Mantenimiento_</h4>
                        </div>
                        <span class="text-2xl font-black text-black font-mono">VALOR_ $10.000 <span class="text-xs text-zinc-400">/ MES</span></span>
                    </div>
                    <div class="group border-b border-zinc-100 pb-10 flex justify-between items-end">
                        <div>
                            <p class="font-mono text-[11px] text-zinc-400 uppercase tracking-[0.2em] mb-4 italic">Hospedaje de alta velocidad</p>
                            <h4 class="text-4xl font-black italic uppercase tracking-tighter group-hover:translate-x-2 transition-transform">Servidor Cloud_</h4>
                        </div>
                        <span class="text-2xl font-black text-black font-mono">VALOR_ $30.000 <span class="text-xs text-zinc-400">/ AÑO</span></span>
                    </div>
                </div>
            </div>
        </section>

        <div class="relative z-10 bg-[#050505]">
            <UbikappPromo client:visible />
            <div class="pb-20">
                <Cta client:visible />
            </div>
        </div>
    </main>
</BaseLayout>

<style is:global>
    /* Laser Scan Animation */
    @keyframes scan {
        0% { transform: translateY(-100%); }
        100% { transform: translateY(400%); }
    }
    
    .animate-scan {
        animation: scan 3s linear infinite;
    }

    h1, h2, h3, h4 {
        font-weight: 950 !important;
        letter-spacing: -0.05em;
    }

    .outline-text {
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.1);
        color: transparent;
        transition: all 1s ease;
    }

    .outline-text:hover {
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.3);
    }
</style>