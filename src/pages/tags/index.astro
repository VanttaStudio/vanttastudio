---
// src/pages/tags/index.astro
import type { AstroSeoProps } from "@astrolib/seo";
import Tags from "@components/blog/Tags.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

const seo: AstroSeoProps = {
    title: "Etiquetas | Vantta Code",
    description: "Explora todos los temas de ingeniería, desarrollo de software y estrategia digital tratados en Vantta Code.",
    canonical: "https://vanttacode.cl/tags/",
    openGraph: {
        title: "Índice de Etiquetas | Vantta Code",
        description: "Navega por las categorías de nuestro contenido técnico y comercial.",
        site_name: "Vantta Code",
    }
};
---

<BaseLayout seo={seo}>
    <section class="bg-zinc-950 min-h-screen text-white pt-32 pb-20">
        <div class="mx-auto px-8 md:px-12 2xl:max-w-7xl">
            <h1 class="font-display text-5xl md:text-7xl font-black uppercase tracking-tighter italic mb-12">
                Explorar <span class="text-lime-400">Temas</span>
            </h1>
            <Tags />
        </div>
    </section>
</BaseLayout>