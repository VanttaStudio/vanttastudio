---
/* src/pages/contact.astro */
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/forms/ContactForm.tsx"; 

const seo = {
    title: "VANTTA // CONTACT_NODE",
    description: "Inicia el protocolo de comunicación con ingeniería Vantta.",
};
---

<BaseLayout seo={seo}>
    <main class="bg-[#050505] min-h-screen pt-40 relative overflow-hidden selection:bg-white selection:text-black">
        
        <div class="absolute inset-0 opacity-[0.03] pointer-events-none"
             style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 40px 40px;">
        </div>

        <section class="relative z-10 container mx-auto px-6 md:px-12 max-w-5xl">
            <div class="mb-20 border-l-2 border-white pl-8">
                <span class="font-mono text-zinc-500 text-[10px] uppercase tracking-[0.5em] font-bold block mb-4">
                    [ SYSTEM_READY ]
                </span>
                <h1 class="text-6xl md:text-8xl font-black uppercase italic tracking-tighter text-white leading-[0.8]">
                    INICIAR <br/> <span class="text-zinc-800" style="-webkit-text-stroke: 1px rgba(255,255,255,0.3);">SOLICITUD_</span>
                </h1>
            </div>

            <ContactForm client:load />
        </section>
    </main>
</BaseLayout>