---
/* src/pages/labs.astro */
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";
import Articles from "@components/blog/Articles.astro";
import Newsletter from "@components/blog/Newsletter.astro";
import { Icon } from "astro-icon/components";

const seo: AstroSeoProps = {
    title: "VANTTA // LABS_DATA_CENTER",
    description: "Proprietary developments, coding trends, and technological evolution hub.",
    canonical: "https://vanttacode.cl/labs/",
};

const syncDate = new Date().toLocaleDateString('en-GB', { 
    day: '2-digit', month: '2-digit', year: 'numeric' 
}).replace(/\//g, '.');
---

<BaseLayout seo={seo}>
    <div class="fixed inset-0 pointer-events-none z-50 overflow-hidden">
        <div class="absolute inset-0 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.1)_50%),linear-gradient(90deg,rgba(163,230,53,0.01),rgba(0,0,0,0),rgba(163,230,53,0.01))] bg-[length:100%_4px,4px_100%] opacity-20"></div>
        <div class="absolute inset-4 border border-zinc-800/10 pointer-events-none"></div>
    </div>

    <main class="bg-[#050505] min-h-screen relative selection:bg-lime-400 selection:text-black">
        <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#ffffff 0.5px, transparent 0.5px); background-size: 30px 30px;"></div>

        <div class="container mx-auto px-6 lg:px-12 pt-32 pb-20 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-0 border border-zinc-900 bg-black/40 backdrop-blur-sm">
                
                <aside class="lg:col-span-3 border-zinc-900 lg:border-r p-8 flex flex-col gap-16">
                    <div class="space-y-2">
                        <div class="flex items-center gap-2">
                            <span class="h-2 w-2 bg-lime-400 animate-pulse rounded-full"></span>
                            <p class="font-mono text-lime-400 text-[10px] uppercase tracking-widest">Live_Session</p>
                        </div>
                        <h2 class="text-4xl font-black italic text-white uppercase tracking-tighter leading-none">
                            VANTTA<br/><span class="text-zinc-800 text-5xl italic">LABS_</span>
                        </h2>
                    </div>

                    <nav class="space-y-4">
                        <p class="font-mono text-zinc-600 text-[9px] uppercase tracking-[0.3em] mb-6">FileSystem_Index</p>
                        <div class="font-mono text-[11px] space-y-2">
                            <div class="text-lime-400/80 flex items-center gap-2 italic">
                                <span>▼</span> root/archive/labs
                            </div>
                            <div class="pl-4 border-l border-zinc-900 ml-1.5 space-y-3 py-2">
                                <a href="#" class="flex items-center gap-2 text-zinc-500 hover:text-white transition-colors group">
                                    <span class="text-zinc-800 group-hover:text-lime-400">├──</span> /engineering
                                </a>
                                <a href="#" class="flex items-center gap-2 text-zinc-500 hover:text-white transition-colors group">
                                    <span class="text-zinc-800 group-hover:text-lime-400">├──</span> /trends_2026
                                </a>
                                <a href="#" class="flex items-center gap-2 text-zinc-500 hover:text-white transition-colors group">
                                    <span class="text-zinc-800 group-hover:text-lime-400">├──</span> /brutalism_dev
                                </a>
                                <a href="#" class="flex items-center gap-2 text-white bg-white/5 px-2 py-1 group">
                                    <span class="text-zinc-800 group-hover:text-lime-400">└──</span> /experiments
                                </a>
                            </div>
                        </div>
                    </nav>

                    <div class="pt-10 border-t border-zinc-900 space-y-6">
                        <div class="space-y-2">
                            <p class="font-mono text-[10px] text-white uppercase tracking-widest">Signal_Subscription_</p>
                            <p class="font-mono text-[8px] text-zinc-600 uppercase leading-relaxed">Suscríbete para recibir transmisiones de código y diseño.</p>
                        </div>
                        <Newsletter />
                    </div>
                </aside>

                <section class="lg:col-span-9 flex flex-col min-h-screen">
                    <div class="h-14 border-b border-zinc-900 flex items-center justify-between px-8 bg-zinc-950/40">
                        <div class="flex items-center gap-6">
                            <div class="flex items-center gap-2 font-mono text-[9px] text-zinc-500">
                                <span class="text-lime-400">ID:</span> VNTT_SCL_NODE_01
                            </div>
                            <span class="h-4 w-px bg-zinc-900"></span>
                            <div class="flex items-center gap-2 font-mono text-[9px] text-zinc-500">
                                <span class="text-lime-400">STATUS:</span> RECEIVING_DATA
                            </div>
                        </div>
                        <div class="font-mono text-[10px] text-zinc-600 uppercase">
                            Sync_Date: <span class="text-zinc-300 tracking-tighter font-bold">{syncDate}</span>
                        </div>
                    </div>

                    <div class="p-8 lg:p-20">
                        <header class="mb-32 relative">
                            <div class="absolute -left-12 top-0 hidden xl:block text-lime-400/20 animate-pulse">
                                <Icon name="ri:arrow-right-down-line" class="w-10 h-10" />
                            </div>

                            <h1 class="text-7xl md:text-[10vw] font-black text-white uppercase italic tracking-[calc(-0.06em)] leading-[0.8] animate-reveal">
                                DATA<br/><span class="text-lime-400 italic">STREAM_</span>
                            </h1>
                            
                            <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-16">
                                <div class="space-y-6">
                                    <p class="text-zinc-400 font-light text-2xl leading-tight">
                                        Exploración profunda en <span class="text-white">ingeniería de software</span>, evolución del diseño y el pulso de las nuevas tecnologías.
                                    </p>
                                    <div class="h-1 w-20 bg-lime-400"></div>
                                </div>
                                <div class="flex flex-col justify-end font-mono text-[10px] text-zinc-700 uppercase tracking-[0.3em] space-y-2 border-l border-zinc-900 pl-8">
                                    <p>// Analítica de Tendencias</p>
                                    <p>// Desarrollo Propietario</p>
                                    <p>// Minimalismo Digital</p>
                                </div>
                            </div>
                        </header>

                        <div class="relative">
                            <Articles />
                            
                            <div class="mt-32 py-16 border-t border-zinc-900 flex flex-col items-center gap-8 group">
                                <div class="w-1 h-20 bg-gradient-to-b from-lime-400 to-transparent"></div>
                                <p class="font-mono text-[9px] text-zinc-600 uppercase tracking-[0.5em]">Final del registro alcanzado</p>
                                <button class="px-8 py-4 border border-zinc-800 font-mono text-[10px] text-zinc-400 uppercase tracking-widest hover:border-lime-400 hover:text-white transition-all">
                                    [ Re-Sincronizar Datos ]
                                </button>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <footer class="container mx-auto px-6 lg:px-12 py-16 border-t border-zinc-900/50 flex flex-col md:flex-row justify-between items-center gap-12">
            <div class="flex flex-col gap-4 items-center md:items-start">
                <div class="flex gap-10 font-mono text-[9px] text-zinc-600 uppercase tracking-widest">
                    <span>Node: VNTT_SCL_01</span>
                    <span class="text-lime-400/50">Uptime: 100% Stable</span>
                </div>
                <p class="font-mono text-[8px] text-zinc-800 uppercase tracking-widest">© 2026 VANTTA code_ // Digital Brutalism in Chile</p>
            </div>
            
            <button id="terminate-btn" class="group relative px-10 py-4 bg-zinc-900 border border-zinc-800 hover:border-lime-400 transition-all duration-500 overflow-hidden">
                <div class="absolute inset-0 bg-lime-400 translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
                <span class="relative z-10 font-mono text-[10px] text-lime-400 group-hover:text-black uppercase tracking-widest font-bold">
                    [ TERMINATE_SESSION ]
                </span>
            </button>
        </footer>
    </main>
</BaseLayout>

<style is:global>
    /* Revelado estilo Terminal */
    .animate-reveal {
        clip-path: polygon(0 0, 0 0, 0 100%, 0% 100%);
        animation: reveal-industrial 1.5s cubic-bezier(0.19, 1, 0.22, 1) forwards;
    }

    @keyframes reveal-industrial {
        to { clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%); }
    }

    /* Scrollbar minimalista */
    .custom-scrollbar::-webkit-scrollbar { width: 3px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #18181b; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #a3e635; }

    ::selection { background: #a3e635; color: #000; }
</style>