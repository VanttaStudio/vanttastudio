---
import { getCollection } from "astro:content";
import type { AstroSeoProps } from "@astrolib/seo";
import MarkdownPostLayout from "../../layouts/MarkdownPostLayout.astro";

export async function getStaticPaths() {
    const projectsEntries = await getCollection("projects");

    return projectsEntries.map((entry) => {
        // Extraemos el slug real ignorando la carpeta de idioma
        // Ejemplo: "es/studiovision" -> "studiovision"
        const slug = entry.slug.split("/").pop();
        
        return { 
            params: { slug }, 
            props: { entry } 
        };
    });
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// VALIDACIÓN DE IMAGEN PARA SEO
// Buscamos la imagen en el frontmatter para el OpenGraph
const ogImage = entry.data.image?.source || entry.data.image || "https://vanttastudio.cl/opengraph/social-og.jpg";

const seo: AstroSeoProps = {
    title: `${entry.data.title} - VANTTA code_`,
    description: entry.data.description,
    canonical: `https://vanttastudio.cl/work/${entry.slug.split('/').pop()}/`,
    openGraph: {
        url: `https://vanttastudio.cl/work/${entry.slug.split('/').pop()}`,
        title: entry.data.title,
        description: entry.data.description,
        images: [
            {
                url: ogImage,
                width: 1200,
                height: 630,
                alt: entry.data.title,
            }
        ],
        site_name: "VANTTA code_",
    },
    twitter: {
        handle: "@vanttastudio",
        cardType: "summary_large_image",
    },
};
---

<MarkdownPostLayout frontmatter={entry.data} body={entry.body} seo={seo}>
    <Content />
</MarkdownPostLayout>