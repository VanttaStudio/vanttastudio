---
// src/pages/work/index.astro
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";
import Title from "@components/global/Title.astro";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const allProjects = (await getCollection("projects"))
    .filter((project) => {
        const [projectLang] = project.slug.split("/");
        return projectLang === lang;
    })
    .map((project) => {
        const [_, ...slugParts] = project.slug.split("/");
        return { ...project, slug: slugParts.join("/") };
    });

const categories = [...new Set(allProjects.map((project) => project.data.tags?.[0]))].filter(Boolean);

const seo = {
    title: (lang === 'es' ? 'Portafolio' : 'Portfolio') + " | Vantta Studio",
    description: "Digital Portfolio and Selected Works",
};
---

<BaseLayout seo={seo}>
    <section class="bg-zinc-950 text-white min-h-screen relative overflow-hidden">
        
        <div class="mx-auto px-6 pt-24 pb-8 md:px-12 md:pt-32 md:pb-12 2xl:max-w-7xl relative z-10">
            <div class="w-full">
                <span class="font-mono text-[10px] uppercase tracking-[0.3em] md:tracking-[0.5em] text-lime-400 mb-4 block">
                    {lang === 'es' ? 'Proyectos Seleccionados' : 'Selected Works'}
                </span>
                
                <Title 
                    title={lang === 'es' ? 'PORTAFOLIO' : 'PORTFOLIO'} 
                    class="text-[13vw] md:text-[11vw] xl:text-[10rem] font-black uppercase tracking-tighter italic leading-[0.8] whitespace-nowrap" 
                />
            </div>
        </div>

        <div class="bg-zinc-950/50 backdrop-blur-md border-y border-zinc-900 relative z-20 sticky top-[4.5rem] md:top-0">
            <div class="mx-auto px-6 py-6 md:px-12 md:py-8 2xl:max-w-7xl">
                <nav class="flex flex-wrap items-center justify-start gap-x-6 gap-y-3 md:gap-x-10">
                    <button 
                        data-filter="all" 
                        class="filter-btn active font-mono text-[10px] md:text-[11px] uppercase tracking-[0.2em] text-lime-400 transition-all hover:text-white"
                    >
                        {lang === 'es' ? '[ Todos ]' : '[ All ]'}
                    </button>
                    
                    {categories.map((cat) => (
                        <button 
                            data-filter={cat.toLowerCase().replace(/\s+/g, '-')} 
                            class="filter-btn font-mono text-[10px] md:text-[11px] uppercase tracking-[0.2em] text-zinc-500 transition-all hover:text-white"
                        >
                            {cat}
                        </button>
                    ))}
                </nav>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 w-full border-t border-zinc-900 relative z-10" id="portfolio-grid">
            {allProjects.map((project) => {
                const projectImage = project.data.image?.source;
                const firstTag = project.data.tags?.[0] || "";
                const filterTag = firstTag.toLowerCase().replace(/\s+/g, '-');
                
                return (
                    <a 
                        href={translatePath(`/work/${project.slug}`)} 
                        data-category={filterTag}
                        class="portfolio-item group relative aspect-[4/3] overflow-hidden bg-zinc-900 block border-b border-zinc-900 md:border-r transition-all duration-500"
                    >
                        <div class="absolute inset-0 h-full w-full overflow-hidden">
                            {projectImage ? (
                                <Image 
                                    src={projectImage} 
                                    alt={project.data.image.alt || project.data.title}
                                    width={800}
                                    height={600}
                                    class="h-full w-full object-cover transition-transform duration-1000 ease-out group-hover:scale-110"
                                />
                            ) : (
                                <div class="flex h-full w-full items-center justify-center bg-zinc-900 text-zinc-800 font-mono text-[10px]">
                                    NO_IMAGE
                                </div>
                            )}
                            <div class="absolute inset-0 bg-black/60 md:bg-black/80 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-500"></div>
                        </div>

                        <div class="absolute inset-0 flex flex-col items-center justify-center p-8 text-center z-20">
                            <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-lime-400 md:translate-y-4 md:opacity-0 md:group-hover:translate-y-0 md:group-hover:opacity-100 transition-all duration-500 delay-75">
                                {firstTag}
                            </span>
                            <h3 class="mt-2 md:mt-4 text-2xl md:text-4xl font-black uppercase tracking-tighter italic leading-none md:translate-y-4 md:opacity-0 md:group-hover:translate-y-0 md:group-hover:opacity-100 transition-all duration-500 delay-150">
                                {project.data.title}
                            </h3>
                            <div class="mt-4 md:mt-6 h-[1px] w-8 md:w-0 bg-white md:group-hover:w-12 transition-all duration-700 delay-300"></div>
                        </div>
                    </a>
                );
            })}
        </div>
    </section>
</BaseLayout>

<script>
    function setupPortfolioFilters() {
        const buttons = document.querySelectorAll('.filter-btn');
        const items = document.querySelectorAll('.portfolio-item') as NodeListOf<HTMLElement>;

        buttons.forEach(btn => {
            btn.addEventListener('click', () => {
                buttons.forEach(b => {
                    b.classList.remove('text-lime-400', 'active');
                    b.classList.add('text-zinc-500');
                });
                btn.classList.add('text-lime-400', 'active');
                btn.classList.remove('text-zinc-500');

                const filter = btn.getAttribute('data-filter');

                items.forEach(item => {
                    const category = item.getAttribute('data-category');
                    if (filter === 'all' || filter === category) {
                        item.style.display = 'block';
                        setTimeout(() => {
                            item.style.opacity = '1';
                            item.style.transform = 'scale(1)';
                        }, 10);
                    } else {
                        item.style.opacity = '0';
                        item.style.transform = 'scale(0.95)';
                        setTimeout(() => {
                            item.style.display = 'none';
                        }, 400);
                    }
                });
            });
        });
    }

    setupPortfolioFilters();
    document.addEventListener('astro:after-swap', setupPortfolioFilters);
</script>

<style>
    .portfolio-item {
        transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .filter-btn.active {
        pointer-events: none;
    }
    h3 {
        font-weight: 900;
        letter-spacing: -0.02em;
        /* Sombra de texto sutil para mejorar lectura sobre imágenes en móvil */
        text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    }
</style>