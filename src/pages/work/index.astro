---
/* src/pages/work/index.astro */
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";
import Title from "@components/global/Title.astro";
import { Icon } from "astro-icon/components";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// Obtención de proyectos (Ajustado a estructura plana si se requiere)
const allProjects = (await getCollection("projects"))
    .sort((a, b) => (b.data.pubDate?.valueOf() || 0) - (a.data.pubDate?.valueOf() || 0));

const categories = [...new Set(allProjects.map((project) => project.data.tags?.[0]))].filter(Boolean);

const seo = {
    title: (lang === 'es' ? 'Portafolio' : 'Portfolio') + " // VANTTA code_",
    description: "Selected Project Outputs and Technical Deployments.",
    canonical: `https://vanttacode.cl/work/`,
};
---

<BaseLayout seo={seo}>
    <section class="bg-zinc-950 text-white min-h-screen relative overflow-hidden selection:bg-lime-400 selection:text-black">
        
        <div class="absolute inset-0 opacity-[0.03] pointer-events-none" 
             style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 40px 40px;">
        </div>

        <div class="container mx-auto px-6 pt-32 pb-16 md:px-12 md:pt-40 md:pb-20 relative z-10">
            <div class="relative">
                <div class="absolute -top-8 -left-2 font-mono text-zinc-800 text-[10px] tracking-[0.5em] uppercase">
                    [ PROJECT_DATABASE // NODE_SCL_01 ]
                </div>
                
                <div class="flex flex-col gap-6">
                    <div class="flex items-center gap-4">
                        <span class="h-px w-12 bg-lime-400"></span>
                        <span class="font-mono text-lime-400 text-[10px] uppercase tracking-[0.5em] animate-pulse">
                            Selected_Outputs
                        </span>
                    </div>
                    
                    <Title 
                        title={lang === 'es' ? 'WORK_' : 'WORK_'} 
                        subtitle={lang === 'es' ? 'Portafolio de despliegue' : 'Deployment Portfolio'} 
                        class="text-7xl md:text-[11vw] xl:text-[13rem] font-black uppercase tracking-[calc(-0.05em)] italic leading-[0.75] whitespace-nowrap" 
                    />
                </div>
            </div>
        </div>

        <div class="bg-zinc-950/80 backdrop-blur-xl border-y border-zinc-900 sticky top-0 z-50">
            <div class="mx-auto px-6 py-6 md:px-12 2xl:max-w-7xl flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div class="flex items-center gap-4">
                    <span class="font-mono text-[9px] text-zinc-700 uppercase tracking-widest mr-4">[ SELECT_SECTOR ]</span>
                    <nav class="flex flex-wrap items-center gap-x-6 gap-y-3">
                        <button 
                            data-filter="all" 
                            class="filter-btn active font-mono text-[10px] uppercase tracking-[0.2em] text-lime-400 transition-all hover:text-white"
                        >
                            :: ALL_UNITS
                        </button>
                        
                        {categories.map((cat) => (
                            <button 
                                data-filter={cat.toLowerCase().replace(/\s+/g, '-')} 
                                class="filter-btn font-mono text-[10px] uppercase tracking-[0.2em] text-zinc-500 transition-all hover:text-white"
                            >
                                / {cat}
                            </button>
                        ))}
                    </nav>
                </div>
                <div class="font-mono text-[9px] text-zinc-800 uppercase tracking-widest hidden lg:block">
                    Total_Modules: {allProjects.length.toString().padStart(2, '0')}
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 w-full bg-zinc-900 gap-px border-b border-zinc-900 relative z-10" id="portfolio-grid">
            {allProjects.map((project, index) => {
                const projectImage = project.data.image?.source;
                const firstTag = project.data.tags?.[0] || "General";
                const filterTag = firstTag.toLowerCase().replace(/\s+/g, '-');
                const hexID = `0x${(index + 1024).toString(16).toUpperCase()}`;
                
                return (
                    <a 
                        href={translatePath(`/work/${project.slug}`)} 
                        data-category={filterTag}
                        class="portfolio-item group relative aspect-square lg:aspect-[4/5] overflow-hidden bg-zinc-950 block transition-all duration-700"
                    >
                        <div class="absolute inset-0 h-full w-full overflow-hidden">
                            {projectImage ? (
                                <Image 
                                    src={projectImage} 
                                    alt={project.data.image.alt || project.data.title}
                                    width={800}
                                    height={1000}
                                    class="h-full w-full object-cover grayscale brightness-[0.3] contrast-[1.1] transition-all duration-1000 ease-out group-hover:scale-105 group-hover:grayscale-0 group-hover:brightness-100"
                                />
                            ) : (
                                <div class="flex h-full w-full items-center justify-center bg-zinc-900 text-zinc-800 font-mono text-[10px]">
                                    NO_IMAGE_DATA
                                </div>
                            )}
                            
                            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-lime-400/20 to-transparent h-[20%] w-full -translate-y-full group-hover:animate-scan pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        </div>

                        <div class="absolute top-6 left-6 z-20 font-mono text-[8px] text-zinc-600 group-hover:text-lime-400 transition-colors uppercase tracking-widest">
                            [ {hexID} ]
                        </div>

                        <div class="absolute inset-0 flex flex-col items-center justify-center p-8 text-center z-20">
                            <span class="font-mono text-[9px] uppercase tracking-[0.5em] text-lime-400 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-700">
                                {firstTag}
                            </span>
                            <h3 class="mt-4 text-3xl md:text-5xl font-black uppercase tracking-tighter italic leading-[0.85] text-white translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-700 delay-100">
                                {project.data.title}
                            </h3>
                            <div class="mt-8 h-px w-0 bg-lime-400 group-hover:w-16 transition-all duration-1000 delay-300 shadow-[0_0_10px_#a3e635]"></div>
                        </div>

                        <div class="absolute top-0 right-0 h-4 w-4 border-t border-r border-white/5 opacity-0 group-hover:opacity-100 group-hover:border-lime-400 transition-all duration-500"></div>
                        <div class="absolute bottom-0 left-0 h-4 w-4 border-b border-l border-white/5 opacity-0 group-hover:opacity-100 group-hover:border-lime-400 transition-all duration-500"></div>
                    </a>
                );
            })}
        </div>

        <footer class="py-20 border-t border-zinc-900">
             <div class="container mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-8 font-mono text-[9px] text-zinc-800 uppercase tracking-[0.4em]">
                <div class="flex items-center gap-6">
                    <span>Registry_Status: Verified</span>
                    <span class="text-zinc-900">|</span>
                    <span>Node: SCL_PROJECTS_V3</span>
                </div>
                <div class="animate-pulse">
                    Scanning_New_Deployments...
                </div>
            </div>
        </footer>
    </section>
</BaseLayout>

<script>
    function setupPortfolioFilters() {
        const buttons = document.querySelectorAll('.filter-btn');
        const items = document.querySelectorAll('.portfolio-item') as NodeListOf<HTMLElement>;

        buttons.forEach(btn => {
            btn.addEventListener('click', () => {
                buttons.forEach(b => {
                    b.classList.remove('text-lime-400', 'active');
                    b.classList.add('text-zinc-500');
                });
                btn.classList.add('text-lime-400', 'active');
                btn.classList.remove('text-zinc-500');

                const filter = btn.getAttribute('data-filter');

                items.forEach(item => {
                    const category = item.getAttribute('data-category');
                    if (filter === 'all' || filter === category) {
                        item.style.display = 'block';
                        setTimeout(() => {
                            item.style.opacity = '1';
                            item.style.transform = 'scale(1)';
                        }, 10);
                    } else {
                        item.style.opacity = '0';
                        item.style.transform = 'scale(0.98)';
                        setTimeout(() => {
                            item.style.display = 'none';
                        }, 400);
                    }
                });
            });
        });
    }

    setupPortfolioFilters();
    document.addEventListener('astro:after-swap', setupPortfolioFilters);
</script>

<style is:global>
    /* Laser Scan Animation */
    @keyframes scan {
        0% { transform: translateY(-100%); }
        100% { transform: translateY(500%); }
    }
    .animate-scan {
        animation: scan 2.5s linear infinite;
    }

    .portfolio-item {
        transition: opacity 0.4s cubic-bezier(0.19, 1, 0.22, 1), transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);
    }

    .filter-btn.active {
        pointer-events: none;
    }

    /* Animación de Revelado Industrial */
    .animate-reveal {
        clip-path: polygon(0 0, 0 0, 0 100%, 0% 100%);
        animation: reveal-industrial 1.4s cubic-bezier(0.19, 1, 0.22, 1) forwards;
    }

    @keyframes reveal-industrial {
        to { clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%); }
    }
</style>