---
/* src/pages/work/index.astro */
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";
import Title from "@components/global/Title.astro";
import { getLangFromUrl, useTranslatedPath } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);

const allProjects = (await getCollection("projects"))
    .sort((a, b) => (b.data.pubDate?.valueOf() || 0) - (a.data.pubDate?.valueOf() || 0));

const categories = [...new Set(allProjects.map((project) => project.data.tags?.[0]))].filter(Boolean);

const seo = {
    title: (lang === 'es' ? 'Proyectos' : 'Projects') + " // VANTTA code_",
    description: "Archivo de sistemas y despliegues técnicos.",
    canonical: `https://vanttacode.cl/work/`,
};
---

<BaseLayout seo={seo}>
    <section class="bg-[#050505] text-white min-h-screen relative overflow-hidden selection:bg-white selection:text-black">
        
        <div class="absolute inset-0 opacity-[0.02] pointer-events-none" 
             style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 40px 40px;">
        </div>

        <div class="container mx-auto px-6 pt-32 pb-16 md:px-12 md:pt-48 md:pb-24 relative z-10">
            <div class="relative flex flex-col gap-8 border-l-2 border-white pl-8 md:pl-12">
                <span class="font-mono text-zinc-600 text-[10px] uppercase tracking-[0.5em] font-black">
                    ARCHIVE_SYSTEMS // 2026
                </span>
                
                <Title 
                    title="PROYECTOS_" 
                    subtitle={lang === 'es' ? 'Selección de sistemas' : 'Systems Archive'} 
                    class="text-7xl md:text-[11vw] xl:text-[13rem] font-black uppercase tracking-tighter italic leading-[0.75] whitespace-nowrap" 
                />
            </div>
        </div>

        <div class="bg-black/90 backdrop-blur-xl border-y border-zinc-900 sticky top-0 z-50">
            <div class="mx-auto px-6 py-8 md:px-12 max-w-[1440px] flex flex-col md:flex-row md:items-center justify-between gap-6">
                <nav class="flex flex-wrap items-center gap-x-8 gap-y-4">
                    <button 
                        data-filter="all" 
                        class="filter-btn active font-mono text-[10px] uppercase tracking-[0.3em] text-white transition-all hover:text-white font-black"
                    >
                        [ TODOS ]
                    </button>
                    
                    {categories.map((cat) => (
                        <button 
                            data-filter={cat.toLowerCase().replace(/\s+/g, '-')} 
                            class="filter-btn font-mono text-[10px] uppercase tracking-[0.3em] text-zinc-600 transition-all hover:text-white"
                        >
                            / {cat}
                        </button>
                    ))}
                </nav>
                <div class="font-mono text-[9px] text-zinc-800 uppercase tracking-widest hidden lg:block">
                    PROYECTOS_ACTUALES: {allProjects.length.toString().padStart(2, '0')}
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 w-full border-b border-zinc-900 relative z-10" id="portfolio-grid">
            {allProjects.map((project, index) => {
                const projectImage = project.data.image?.source;
                const firstTag = project.data.tags?.[0] || "Sistema";
                const filterTag = firstTag.toLowerCase().replace(/\s+/g, '-');
                const projectID = `_P${(index + 1).toString().padStart(2, '0')}`;
                
                return (
                    <a 
                        href={translatePath(`/work/${project.slug}`)} 
                        data-category={filterTag}
                        class="portfolio-item group relative aspect-square lg:aspect-[4/5] overflow-hidden bg-zinc-950 border-r border-b border-zinc-900 block"
                    >
                        <div class="absolute inset-0 h-full w-full overflow-hidden">
                            {projectImage ? (
                                <Image 
                                    src={projectImage} 
                                    alt={project.data.image.alt || project.data.title}
                                    width={800}
                                    height={1000}
                                    class="h-full w-full object-cover grayscale opacity-30 transition-all duration-1000 ease-out group-hover:scale-110 group-hover:grayscale-0 group-hover:opacity-100"
                                />
                            ) : (
                                <div class="flex h-full w-full items-center justify-center bg-zinc-900 text-zinc-800 font-mono text-[10px]">SIN_DATA</div>
                            )}
                            <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-[#050505]/20 to-transparent opacity-80 group-hover:opacity-40 transition-opacity" />
                        </div>

                        <div class="absolute top-8 left-8 z-20 font-mono text-[10px] text-zinc-700 group-hover:text-white transition-colors">
                            {projectID}
                        </div>

                        <div class="absolute inset-0 flex flex-col items-start justify-end p-10 z-20 translate-y-4 group-hover:translate-y-0 transition-transform duration-700">
                            <span class="font-mono text-[9px] uppercase tracking-[0.5em] text-zinc-500 mb-3">
                                {firstTag}
                            </span>
                            <h3 class="text-4xl md:text-5xl font-black uppercase italic tracking-tighter leading-[0.8] text-white">
                                {project.data.title}
                            </h3>
                            <div class="mt-6 h-px w-0 bg-white group-hover:w-full transition-all duration-700 ease-out shadow-[0_0_15px_rgba(255,255,255,0.5)]" />
                        </div>
                    </a>
                );
            })}
        </div>

        <footer class="py-24">
            <div class="container mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-8 font-mono text-[9px] text-zinc-800 uppercase tracking-[0.5em]">
                <div class="flex items-center gap-6">
                    <span>MAGALLANES_NODE_CL</span>
                    <span>|</span>
                    <span>VANTTA CORE 2026</span>
                </div>
            </div>
        </footer>
    </section>
</BaseLayout>

<script>
    function setupPortfolioFilters() {
        const buttons = document.querySelectorAll('.filter-btn');
        const items = document.querySelectorAll('.portfolio-item') as NodeListOf<HTMLElement>;

        buttons.forEach(btn => {
            btn.addEventListener('click', () => {
                buttons.forEach(b => {
                    b.classList.remove('text-white', 'active', 'font-black');
                    b.classList.add('text-zinc-600');
                });
                btn.classList.add('text-white', 'active', 'font-black');
                btn.classList.remove('text-zinc-600');

                const filter = btn.getAttribute('data-filter');

                items.forEach(item => {
                    const category = item.getAttribute('data-category');
                    if (filter === 'all' || filter === category) {
                        item.style.display = 'block';
                        setTimeout(() => { item.style.opacity = '1'; }, 10);
                    } else {
                        item.style.opacity = '0';
                        setTimeout(() => { item.style.display = 'none'; }, 400);
                    }
                });
            });
        });
    }

    setupPortfolioFilters();
    document.addEventListener('astro:after-swap', setupPortfolioFilters);
</script>