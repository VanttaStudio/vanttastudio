---
// src/pages/index.astro
import BaseLayout from "@/layouts/BaseLayout.astro";

// React Components
import Hero from "@components/landing/Hero.jsx";
import AllInOne from "@components/landing/AllInOne.jsx";
import UbikappPromo from "@components/ubikapp/UbikappPromo.jsx";
import Testimonials from "@components/landing/Testimonials.jsx";
import Tagline from "@components/landing/Tagline.jsx";
import Faq from "@components/landing/Faq.jsx";
import Cta from "@components/landing/Cta.jsx";

// Astro Components (Originales)
import WorkPreview from "@components/landing/WorkPreview.astro";
import Services from "@components/landing/Services.astro";

const seo = {
    title: "VANTTA code_ | Ingeniería de Software & Estrategia",
    description: "Estudio de ingeniería digital especializado en desarrollo web...",
};
---

<BaseLayout seo={seo}>
    <div class="relative bg-zinc-950 w-full overflow-hidden">
        
        <div class="relative min-h-screen w-full border-b border-zinc-900">
             <Hero client:load />
        </div>

        <div class="relative z-20 bg-zinc-950">
            <WorkPreview class="!pt-20 pb-20 lg:!pt-36 lg:pb-40" />
        </div>

        <div class="relative z-10 bg-zinc-950">
            <Services />
        </div>

        <AllInOne client:visible />

        <div class="relative z-10 bg-zinc-950 border-t border-zinc-900">
            <UbikappPromo client:visible />
        </div>

        <Testimonials client:visible />

        <Tagline client:visible />

        <div class="relative z-10 bg-zinc-950 py-20 border-t border-zinc-900">
            <Faq client:visible />
        </div>

        <Cta client:visible />
        
    </div>
</BaseLayout>