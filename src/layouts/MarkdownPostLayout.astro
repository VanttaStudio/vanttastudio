---
/* src/layouts/MarkdownPostLayout.astro */
import BaseLayout from "./BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getLangFromUrl, useTranslatedPath } from "@i18n/utils";

const { frontmatter, seo } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
---

<BaseLayout seo={seo}>
    <main class="min-h-screen bg-[#050505] text-white pt-32 pb-24 relative selection:bg-white selection:text-black">
        
        <div class="absolute inset-0 opacity-[0.02] pointer-events-none fixed" 
             style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 40px 40px;">
        </div>

        <article class="container mx-auto px-6 md:px-12 lg:px-24 max-w-[1440px] relative z-10">
            
            <nav class="mb-16 lg:mb-24 flex justify-between items-end border-b border-zinc-900 pb-8">
                <a href={translatePath('/blog')} class="group inline-flex items-center gap-4 font-mono text-[10px] uppercase tracking-[0.3em] text-zinc-600 hover:text-white transition-colors">
                    <div class="border border-zinc-800 p-2 group-hover:border-white transition-colors bg-zinc-950">
                        <Icon name="ic:baseline-arrow-back" class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
                    </div>
                    [ RETURN_TO_INDEX ]
                </a>

                <div class="hidden md:block font-mono text-[9px] text-zinc-800 uppercase tracking-[0.4em] font-black">
                    READING_MODE: ACTIVE
                </div>
            </nav>

            <div class="max-w-5xl mx-auto">
                <slot />
            </div>

            <footer class="max-w-5xl mx-auto mt-40 pt-12 border-t border-zinc-900 flex flex-col md:flex-row justify-between items-center gap-8 font-mono text-[9px] uppercase tracking-[0.4em] text-zinc-600 font-bold">
                <div class="flex items-center gap-4">
                    <span class="w-2 h-2 bg-zinc-800"></span>
                    <span>END_OF_FILE_STREAM</span>
                </div>
                
                <a href="#" class="group flex items-center gap-3 hover:text-white transition-colors">
                    SCROLL_TO_TOP
                    <Icon name="ic:baseline-arrow-upward" class="w-4 h-4 group-hover:-translate-y-1 transition-transform" />
                </a>
            </footer>

        </article>
    </main>
</BaseLayout>